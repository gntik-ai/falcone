node_modules/
dist/
coverage/
.turbo/
.DS_Store
.env
.env.*
!.env.example
charts/in-falcone/values/local.yaml
.agents/
.codex/
.specify/
specs/
!openspec/specs/
!openspec/specs/**
# OpenSpec change deltas live under each change's specs/ — keep them tracked too
!openspec/changes/**/specs/
!openspec/changes/**/specs/**
# E2E Playwright specs live under tests/e2e/specs/ — keep per-issue regression specs tracked
!tests/e2e/specs/
!tests/e2e/specs/**

# Playwright E2E run output (reports, traces, screenshots) — never commit
tests/e2e/test-results/
tests/e2e/playwright-report/

# Local cluster kubeconfig (sensitive credentials — never commit)
kubeconfig-test-cluster-b.yaml

# TypeScript incremental build artifacts
*.tsbuildinfo

# kind dev runtime: abandoned OpenWhisk attempt + browser verification screenshots
deploy/kind/openwhisk/
deploy/kind/.uiout/

# kind web-console build output (served by static-server.mjs)
deploy/kind/web-console/dist/

# Generated third-party license report (SBOM) — produced by `pnpm sbom:licenses*` / CI, not committed
sbom/

# Helm chart dependency build artifacts — regenerated by `helm dependency build` (and in CI), not committed
**/Chart.lock
**/charts/*.tgz
