{
  "config": {
    "default": true,
    "MD013": false,
    "MD032": false,
    "MD033": false,
    "MD036": false,
    "MD060": false,
    "MD041": false
  },
  "ignores": [
    "**/node_modules/**/*.md"
  ],
  "globs": [
    "README*.md",
    "docs/**/*.md",
    "tests/**/*.md",
    "apps/**/*.md",
    "services/**/*.md"
  ]
}
