{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "sdk-generation-completed-event",
  "title": "SdkGenerationCompletedEvent",
  "type": "object",
  "required": ["eventType", "timestamp", "tenantId", "workspaceId", "language", "specVersion", "status"],
  "properties": {
    "eventType": { "type": "string", "const": "sdk.generation.completed" },
    "timestamp": { "type": "string", "format": "date-time" },
    "tenantId": { "type": "string", "format": "uuid" },
    "workspaceId": { "type": "string", "format": "uuid" },
    "language": { "type": "string", "enum": ["typescript", "python"] },
    "specVersion": { "type": "string" },
    "status": { "type": "string", "enum": ["ready", "failed"] },
    "errorMessage": { "type": ["string", "null"] }
  }
}
