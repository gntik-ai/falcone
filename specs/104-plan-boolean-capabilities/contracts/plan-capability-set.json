{ "actionName": "plan-capability-set", "description": "Enable or disable plan capabilities.", "auth": { "actorType": "superadmin" }, "input": { "type": "object", "required": ["planId", "capabilities"] }, "output": { "type": "object", "required": ["planId", "planSlug", "changed", "unchanged", "effectiveCapabilities"] }, "errors": [{ "code": "INVALID_CAPABILITY_KEY", "httpStatus": 400, "description": "Unknown capability key" }, { "code": "INVALID_CAPABILITY_VALUE", "httpStatus": 400, "description": "Capability values must be boolean" }, { "code": "NO_CAPABILITIES_SPECIFIED", "httpStatus": 400, "description": "At least one capability is required" }, { "code": "PLAN_NOT_FOUND", "httpStatus": 404, "description": "Plan not found" }, { "code": "PLAN_ARCHIVED", "httpStatus": 409, "description": "Archived plans are immutable" }, { "code": "CONCURRENT_CAPABILITY_CONFLICT", "httpStatus": 409, "description": "Capability update lock conflict" }] }