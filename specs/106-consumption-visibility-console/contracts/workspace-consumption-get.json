{
  "actionName": "workspace-consumption-get",
  "description": "Return workspace-level effective limits and current consumption for each quota dimension. For each dimension: returns the workspace sub-quota if set (workspaceSource=workspace_sub_quota) or indicates the workspace shares the tenant pool (workspaceSource=tenant_shared_pool). Boolean capabilities are not included here — use tenant-effective-entitlements-get for capabilities.",
  "auth": { "actorType": "superadmin|tenant_owner|workspace_admin" },
  "input": {
    "type": "object",
    "required": ["tenantId", "workspaceId"],
    "properties": {
      "tenantId": { "type": "string" },
      "workspaceId": { "type": "string" }
    }
  },
  "output": {
    "type": "object",
    "required": ["tenantId", "workspaceId", "snapshotAt", "dimensions"],
    "properties": {
      "tenantId": { "type": "string" },
      "workspaceId": { "type": "string" },
      "snapshotAt": { "type": "string", "format": "date-time" },
      "dimensions": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["dimensionKey", "displayLabel", "unit", "tenantEffectiveValue", "workspaceLimit", "workspaceSource", "currentUsage", "usageStatus"],
          "properties": {
            "dimensionKey": { "type": "string" },
            "displayLabel": { "type": "string" },
            "unit": { "type": ["string", "null"] },
            "tenantEffectiveValue": {
              "type": "integer",
              "description": "Tenant-level resolved limit. -1 = unlimited."
            },
            "workspaceLimit": {
              "type": ["integer", "null"],
              "description": "null = workspace uses shared tenant pool (no sub-quota set)"
            },
            "workspaceSource": {
              "type": "string",
              "enum": ["workspace_sub_quota", "tenant_shared_pool"]
            },
            "currentUsage": {
              "type": ["integer", "null"],
              "description": "Workspace-scoped resource count. null when usageStatus=unknown."
            },
            "usageStatus": {
              "type": "string",
              "enum": ["within_limit", "approaching_limit", "at_limit", "over_limit", "unknown"]
            },
            "usageUnknownReason": {
              "type": ["string", "null"],
              "description": "CONSUMPTION_QUERY_FAILED | NO_QUERY_MAPPING | WORKSPACE_SCOPE_NOT_SUPPORTED"
            }
          }
        }
      }
    }
  },
  "errors": [
    { "code": "FORBIDDEN", "httpStatus": 403, "description": "Actor cannot read limits for that tenant/workspace" },
    { "code": "TENANT_NOT_FOUND", "httpStatus": 404, "description": "Tenant not found" },
    { "code": "WORKSPACE_NOT_FOUND", "httpStatus": 404, "description": "Workspace not found within that tenant" }
  ],
  "apisixRoutes": [
    {
      "method": "GET",
      "path": "/v1/workspaces/{workspaceId}/consumption",
      "auth": "workspace_admin|tenant_owner",
      "description": "Workspace admin or tenant owner: own workspace consumption"
    },
    {
      "method": "GET",
      "path": "/v1/tenants/{tenantId}/workspaces/{workspaceId}/consumption",
      "auth": "superadmin",
      "description": "Superadmin: any workspace consumption"
    }
  ]
}
