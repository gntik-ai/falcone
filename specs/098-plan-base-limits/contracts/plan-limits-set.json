{
  "action": "plan-limits-set",
  "auth": { "role": "superadmin" },
  "input": {
    "type": "object",
    "additionalProperties": false,
    "required": ["planId", "dimensionKey", "value"],
    "properties": {
      "planId": { "type": "string", "minLength": 1 },
      "dimensionKey": { "type": "string", "pattern": "^[a-z][a-z0-9_]{1,62}$" },
      "value": { "type": "integer", "minimum": -1 }
    }
  },
  "output": {
    "type": "object",
    "required": ["planId", "dimensionKey", "previousValue", "newValue", "source"],
    "properties": {
      "planId": { "type": "string" },
      "dimensionKey": { "type": "string" },
      "previousValue": { "type": ["integer", "null"] },
      "newValue": { "type": "integer", "minimum": -1 },
      "source": { "type": "string", "const": "explicit" }
    }
  },
  "errors": [
    { "code": "FORBIDDEN", "httpStatus": 403, "description": "Superadmin access is required." },
    { "code": "INVALID_DIMENSION_KEY", "httpStatus": 400, "description": "The dimension key is malformed or not registered in the catalog." },
    { "code": "INVALID_LIMIT_VALUE", "httpStatus": 400, "description": "Limit value must be an integer >= -1." },
    { "code": "PLAN_NOT_FOUND", "httpStatus": 404, "description": "The target plan does not exist." },
    { "code": "PLAN_LIMITS_FROZEN", "httpStatus": 409, "description": "Deprecated or archived plans cannot be mutated." }
  ]
}
