{
  "action": "plan-limits-profile-get",
  "auth": { "role": "superadmin" },
  "input": {
    "type": "object",
    "additionalProperties": false,
    "required": ["planId"],
    "properties": {
      "planId": { "type": "string", "minLength": 1 }
    }
  },
  "output": {
    "type": "object",
    "required": ["planId", "planSlug", "planStatus", "profile"],
    "properties": {
      "planId": { "type": "string" },
      "planSlug": { "type": "string" },
      "planStatus": { "type": "string", "enum": ["draft", "active", "deprecated", "archived"] },
      "profile": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["dimensionKey", "displayLabel", "unit", "effectiveValue", "source", "unlimitedSentinel"],
          "properties": {
            "dimensionKey": { "type": "string" },
            "displayLabel": { "type": "string" },
            "unit": { "type": "string", "enum": ["count", "bytes"] },
            "effectiveValue": { "type": "integer", "minimum": -1 },
            "source": { "type": "string", "enum": ["explicit", "default"] },
            "unlimitedSentinel": { "type": "boolean" }
          }
        }
      }
    }
  },
  "errors": [
    { "code": "FORBIDDEN", "httpStatus": 403, "description": "Superadmin access is required." },
    { "code": "PLAN_NOT_FOUND", "httpStatus": 404, "description": "The target plan does not exist." }
  ]
}
