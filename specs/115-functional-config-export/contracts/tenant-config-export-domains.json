{
  "openapi": "3.0.3",
  "info": {
    "title": "Tenant Config Export — Exportable Domains",
    "version": "1.0.0",
    "description": "Returns the list of exportable configuration domains for a tenant, with their availability status according to the active deployment profile."
  },
  "paths": {
    "/v1/admin/tenants/{tenant_id}/config/export/domains": {
      "get": {
        "operationId": "getExportableDomains",
        "summary": "List exportable configuration domains for a tenant",
        "description": "Returns the six configuration domains and their availability according to the active deployment profile. Useful for UIs and automation to present valid export options before initiating an export.",
        "tags": ["config-export"],
        "security": [{ "openIdConnect": ["platform:admin:config:export"] }],
        "parameters": [
          {
            "name": "tenant_id",
            "in": "path",
            "required": true,
            "description": "Tenant identifier",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "List of exportable domains with availability status",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["tenant_id", "deployment_profile", "queried_at", "domains"],
                  "properties": {
                    "tenant_id": { "type": "string" },
                    "deployment_profile": { "type": "string", "example": "standard" },
                    "queried_at": { "type": "string", "format": "date-time" },
                    "domains": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "required": ["domain_key", "availability", "description"],
                        "properties": {
                          "domain_key": {
                            "type": "string",
                            "enum": ["iam", "postgres_metadata", "mongo_metadata", "kafka", "functions", "storage"]
                          },
                          "availability": {
                            "type": "string",
                            "enum": ["available", "not_available", "degraded"],
                            "description": "available: collector configured and reachable; not_available: component not in deployment profile; degraded: component in profile but currently unreachable"
                          },
                          "description": {
                            "type": "string",
                            "description": "Human-readable description of the domain"
                          },
                          "reason": {
                            "type": "string",
                            "nullable": true,
                            "description": "Reason message. Present when availability is not_available or degraded."
                          }
                        }
                      },
                      "example": [
                        { "domain_key": "iam", "availability": "available", "description": "IAM configuration (Keycloak realms, roles, clients, scopes)" },
                        { "domain_key": "postgres_metadata", "availability": "available", "description": "PostgreSQL schema metadata (schemas, tables, indexes, grants)" },
                        { "domain_key": "mongo_metadata", "availability": "not_available", "reason": "MongoDB not enabled in current deployment profile", "description": "MongoDB collection metadata (databases, collections, indexes)" },
                        { "domain_key": "kafka", "availability": "available", "description": "Kafka configuration (topics, ACLs, consumer groups)" },
                        { "domain_key": "functions", "availability": "not_available", "reason": "OpenWhisk not present in deployment profile: standard", "description": "Serverless function configuration (actions, packages, triggers, rules)" },
                        { "domain_key": "storage", "availability": "available", "description": "Object storage configuration (buckets, policies, lifecycle rules, CORS)" }
                      ]
                    }
                  }
                }
              }
            }
          },
          "403": {
            "description": "Insufficient role",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": { "type": "string" },
                    "message": { "type": "string" }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Tenant not found"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "openIdConnect": {
        "type": "openIdConnect",
        "openIdConnectUrl": "/.well-known/openid-configuration"
      }
    }
  }
}
