{
  "openapi": "3.0.3",
  "info": {
    "title": "Tenant Functional Config Export",
    "version": "1.0.0",
    "description": "Export the functional configuration of a tenant across all managed subsystems (IAM, PostgreSQL metadata, MongoDB metadata, Kafka topics/ACLs, OpenWhisk functions, S3 buckets/policies)."
  },
  "paths": {
    "/v1/admin/tenants/{tenant_id}/config/export": {
      "post": {
        "operationId": "exportTenantConfig",
        "summary": "Export functional configuration of a tenant",
        "description": "Collects functional configuration from all requested domains and returns a structured JSON artifact. Secrets are redacted. Supports partial degradation: if a collector fails, the other domains are still exported and the response is HTTP 207.",
        "tags": ["config-export"],
        "security": [{ "openIdConnect": ["platform:admin:config:export"] }],
        "parameters": [
          {
            "name": "tenant_id",
            "in": "path",
            "required": true,
            "description": "Tenant identifier",
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "domains": {
                    "type": "array",
                    "description": "Optional list of domain keys to export. If omitted, all available domains are exported.",
                    "items": {
                      "type": "string",
                      "enum": ["iam", "postgres_metadata", "mongo_metadata", "kafka", "functions", "storage"]
                    },
                    "example": ["iam", "kafka"]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Full export — all requested domains exported successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ExportArtifact" }
              }
            }
          },
          "207": {
            "description": "Partial export — at least one domain failed; other domains exported normally",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ExportArtifact" }
              }
            }
          },
          "400": {
            "description": "Unknown domain key in request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "403": {
            "description": "Insufficient role (tenant owners are not permitted)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "404": {
            "description": "Tenant not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "422": {
            "description": "Artifact exceeds maximum size limit (EXPORT_MAX_ARTIFACT_BYTES). Use domain filtering to reduce scope.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ExportArtifact": {
        "type": "object",
        "required": ["export_timestamp", "tenant_id", "format_version", "deployment_profile", "correlation_id", "domains"],
        "properties": {
          "export_timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "UTC ISO 8601 timestamp of when the export was initiated"
          },
          "tenant_id": { "type": "string" },
          "format_version": { "type": "string", "example": "1.0" },
          "deployment_profile": { "type": "string", "example": "standard" },
          "correlation_id": { "type": "string" },
          "domains": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/DomainResult" }
          }
        }
      },
      "DomainResult": {
        "type": "object",
        "required": ["domain_key", "status", "exported_at"],
        "properties": {
          "domain_key": {
            "type": "string",
            "enum": ["iam", "postgres_metadata", "mongo_metadata", "kafka", "functions", "storage"]
          },
          "status": {
            "type": "string",
            "enum": ["ok", "empty", "error", "not_available", "not_requested"],
            "description": "ok: exported; empty: no config found; error: collector failed; not_available: component not in deployment profile; not_requested: domain not in request filter"
          },
          "exported_at": {
            "type": "string",
            "format": "date-time",
            "description": "UTC ISO 8601 timestamp of when this domain section was collected"
          },
          "items_count": {
            "type": "integer",
            "description": "Number of top-level configuration items exported. Present when status is ok or empty."
          },
          "data": {
            "type": "object",
            "nullable": true,
            "description": "Domain-specific configuration data. null when status is error, not_available, or not_requested."
          },
          "error": {
            "type": "string",
            "nullable": true,
            "description": "Error message. Present when status is error."
          },
          "reason": {
            "type": "string",
            "nullable": true,
            "description": "Reason message. Present when status is not_available or not_requested."
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": ["error", "message"],
        "properties": {
          "error": { "type": "string", "description": "Machine-readable error code" },
          "message": { "type": "string", "description": "Human-readable error description" },
          "correlation_id": { "type": "string" }
        }
      }
    },
    "securitySchemes": {
      "openIdConnect": {
        "type": "openIdConnect",
        "openIdConnectUrl": "/.well-known/openid-configuration"
      }
    }
  }
}
