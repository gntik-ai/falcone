{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://falcone.local/specs/102-plan-transition-limit-policies/contracts/kafka-events.json",
  "title": "Plan Transition Policy Kafka Events",
  "description": "Schema for all Kafka events emitted by feature 102.",
  "oneOf": [
    { "$ref": "#/definitions/transitionEvaluatedEvent" },
    { "$ref": "#/definitions/transitionBlockedEvent" },
    { "$ref": "#/definitions/excessDetectedEvent" },
    { "$ref": "#/definitions/gracePeriodStartedEvent" },
    { "$ref": "#/definitions/gracePeriodExpiredEvent" },
    { "$ref": "#/definitions/gracePeriodResolvedEvent" },
    { "$ref": "#/definitions/creationBlockedEvent" }
  ],
  "definitions": {
    "uuidOrNull": {
      "type": ["string", "null"],
      "format": "uuid"
    },
    "transitionDirection": {
      "type": "string",
      "enum": ["upgrade", "downgrade", "lateral", "initial_assignment", "equivalent"]
    },
    "finalOutcome": {
      "type": "string",
      "enum": ["allowed", "allowed_with_approval", "blocked_by_rule", "blocked_by_excess", "no_op"]
    },
    "policyMode": {
      "type": "string",
      "enum": ["grace_period", "block_creation", "block_transition"]
    },
    "policyLayer": {
      "type": "string",
      "enum": ["dimension_override", "transition_override", "platform_default", "built_in_fallback"]
    },
    "overLimitDimension": {
      "type": "object",
      "required": [
        "dimensionKey",
        "effectiveLimit",
        "observedConsumption",
        "policyApplied",
        "policyLayer"
      ],
      "properties": {
        "dimensionKey": { "type": "string", "maxLength": 64 },
        "effectiveLimit": { "type": "integer" },
        "observedConsumption": { "type": "integer" },
        "policyApplied": { "$ref": "#/definitions/policyMode" },
        "policyLayer": { "$ref": "#/definitions/policyLayer" },
        "gracePeriodDays": { "type": ["integer", "null"], "minimum": 1 },
        "expiresAt": { "type": ["string", "null"], "format": "date-time" }
      },
      "additionalProperties": false
    },
    "baseEvent": {
      "type": "object",
      "required": ["eventType", "correlationId", "actorId", "tenantId", "timestamp"],
      "properties": {
        "eventType": { "type": "string" },
        "correlationId": { "type": "string" },
        "actorId": { "type": "string" },
        "tenantId": { "type": "string" },
        "sourcePlanId": { "$ref": "#/definitions/uuidOrNull" },
        "targetPlanId": { "$ref": "#/definitions/uuidOrNull" },
        "transitionDirection": { "$ref": "#/definitions/transitionDirection" },
        "finalOutcome": { "$ref": "#/definitions/finalOutcome" },
        "overLimitDimensions": {
          "type": "array",
          "items": { "$ref": "#/definitions/overLimitDimension" }
        },
        "dimensionKey": { "type": "string", "maxLength": 64 },
        "effectiveLimit": { "type": "integer" },
        "observedConsumption": { "type": "integer" },
        "policyMode": { "$ref": "#/definitions/policyMode" },
        "status": {
          "type": "string",
          "enum": ["active", "expired_escalated", "resolved"]
        },
        "expiresAt": { "type": ["string", "null"], "format": "date-time" },
        "blockedOperation": { "type": "string" },
        "message": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    },
    "transitionEvaluatedEvent": {
      "allOf": [
        { "$ref": "#/definitions/baseEvent" },
        {
          "type": "object",
          "required": [
            "eventType",
            "sourcePlanId",
            "targetPlanId",
            "transitionDirection",
            "finalOutcome",
            "overLimitDimensions"
          ],
          "properties": {
            "eventType": { "const": "console.plan.transition.evaluated" }
          }
        }
      ]
    },
    "transitionBlockedEvent": {
      "allOf": [
        { "$ref": "#/definitions/baseEvent" },
        {
          "type": "object",
          "required": [
            "eventType",
            "sourcePlanId",
            "targetPlanId",
            "transitionDirection",
            "finalOutcome",
            "message"
          ],
          "properties": {
            "eventType": { "const": "console.plan.transition.blocked" }
          }
        }
      ]
    },
    "excessDetectedEvent": {
      "allOf": [
        { "$ref": "#/definitions/baseEvent" },
        {
          "type": "object",
          "required": [
            "eventType",
            "sourcePlanId",
            "targetPlanId",
            "transitionDirection",
            "dimensionKey",
            "effectiveLimit",
            "observedConsumption",
            "policyMode"
          ],
          "properties": {
            "eventType": { "const": "console.plan.excess.detected" }
          }
        }
      ]
    },
    "gracePeriodStartedEvent": {
      "allOf": [
        { "$ref": "#/definitions/baseEvent" },
        {
          "type": "object",
          "required": [
            "eventType",
            "dimensionKey",
            "effectiveLimit",
            "observedConsumption",
            "policyMode",
            "expiresAt",
            "status"
          ],
          "properties": {
            "eventType": { "const": "console.plan.grace_period.started" },
            "policyMode": { "const": "grace_period" },
            "status": { "const": "active" }
          }
        }
      ]
    },
    "gracePeriodExpiredEvent": {
      "allOf": [
        { "$ref": "#/definitions/baseEvent" },
        {
          "type": "object",
          "required": [
            "eventType",
            "dimensionKey",
            "effectiveLimit",
            "observedConsumption",
            "policyMode",
            "expiresAt",
            "status"
          ],
          "properties": {
            "eventType": { "const": "console.plan.grace_period.expired" },
            "policyMode": { "const": "block_creation" },
            "status": { "const": "expired_escalated" }
          }
        }
      ]
    },
    "gracePeriodResolvedEvent": {
      "allOf": [
        { "$ref": "#/definitions/baseEvent" },
        {
          "type": "object",
          "required": ["eventType", "dimensionKey", "status"],
          "properties": {
            "eventType": { "const": "console.plan.grace_period.resolved" },
            "status": { "const": "resolved" }
          }
        }
      ]
    },
    "creationBlockedEvent": {
      "allOf": [
        { "$ref": "#/definitions/baseEvent" },
        {
          "type": "object",
          "required": [
            "eventType",
            "dimensionKey",
            "effectiveLimit",
            "observedConsumption",
            "policyMode",
            "blockedOperation",
            "message"
          ],
          "properties": {
            "eventType": { "const": "console.plan.creation.blocked" }
          }
        }
      ]
    }
  }
}
