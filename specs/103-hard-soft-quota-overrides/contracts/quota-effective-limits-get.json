{
  "action": "quota-effective-limits-get",
  "description": "Resolve effective limits for a tenant (override > plan > catalog default) with source attribution",
  "auth": "superadmin JWT (any tenant) or tenant owner JWT (own tenant only)",
  "input": {
    "type": "object",
    "required": ["tenantId"],
    "properties": {
      "tenantId": { "type": "string", "description": "Target tenant (from JWT claim for tenant owners)" }
    }
  },
  "output": {
    "status": 200,
    "type": "object",
    "properties": {
      "tenantId": { "type": "string" },
      "planSlug": { "type": "string" },
      "planStatus": { "type": "string" },
      "effectiveLimits": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "dimensionKey": { "type": "string" },
            "displayLabel": { "type": "string" },
            "unit": { "type": "string", "enum": ["count", "bytes"] },
            "effectiveValue": { "type": "integer" },
            "source": { "type": "string", "enum": ["override", "plan", "default"] },
            "quotaType": { "type": "string", "enum": ["hard", "soft"] },
            "graceMargin": { "type": "integer" },
            "unlimitedSentinel": { "type": "boolean" },
            "overrideMetadata": {
              "type": ["object", "null"],
              "description": "Only included for superadmin callers",
              "properties": {
                "overrideId": { "type": "string", "format": "uuid" },
                "expiresAt": { "type": ["string", "null"] },
                "justification": { "type": "string" }
              }
            }
          }
        }
      }
    }
  },
  "noAssignmentResponse": {
    "tenantId": "<string>",
    "noAssignment": true,
    "effectiveLimits": []
  },
  "errors": [
    { "status": 403, "code": "FORBIDDEN", "description": "Tenant owner attempting to query another tenant" },
    { "status": 404, "code": "TENANT_NOT_FOUND", "description": "tenantId does not exist" }
  ]
}
