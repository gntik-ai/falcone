{
  "action": "quota-override-revoke",
  "description": "Revoke an active quota override, reverting the tenant to base plan limits",
  "auth": "superadmin JWT",
  "input": {
    "type": "object",
    "required": ["overrideId", "justification"],
    "properties": {
      "overrideId": { "type": "string", "format": "uuid", "description": "Override to revoke" },
      "justification": { "type": "string", "minLength": 1, "maxLength": 1000, "description": "Reason for revocation" }
    }
  },
  "output": {
    "status": 200,
    "type": "object",
    "properties": {
      "overrideId": { "type": "string", "format": "uuid" },
      "tenantId": { "type": "string" },
      "dimensionKey": { "type": "string" },
      "revokedValue": { "type": "integer" },
      "effectiveValueAfterRevocation": { "type": "integer" },
      "effectiveSource": { "type": "string", "enum": ["plan", "default"] },
      "justification": { "type": "string" },
      "revokedAt": { "type": "string", "format": "date-time" },
      "revokedBy": { "type": "string" }
    }
  },
  "errors": [
    { "status": 404, "code": "OVERRIDE_NOT_FOUND", "description": "overrideId does not exist" },
    { "status": 409, "code": "OVERRIDE_NOT_ACTIVE", "description": "Override is not in active status" },
    { "status": 400, "code": "JUSTIFICATION_REQUIRED", "description": "justification is empty or missing" },
    { "status": 403, "code": "FORBIDDEN", "description": "Caller is not a superadmin" }
  ]
}
