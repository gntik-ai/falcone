{
  "action": "quota-override-create",
  "description": "Create a per-tenant quota override for a specific dimension",
  "auth": "superadmin JWT",
  "input": {
    "type": "object",
    "required": ["tenantId", "dimensionKey", "overrideValue", "justification"],
    "properties": {
      "tenantId": { "type": "string", "description": "Target tenant identifier" },
      "dimensionKey": { "type": "string", "maxLength": 64, "description": "Quota dimension key from catalog" },
      "overrideValue": { "type": "integer", "minimum": -1, "description": "Override limit value; -1 = unlimited" },
      "quotaType": { "type": "string", "enum": ["hard", "soft"], "default": "hard", "description": "Enforcement type for this override" },
      "graceMargin": { "type": "integer", "minimum": 0, "description": "Grace margin (required when quotaType = soft)" },
      "justification": { "type": "string", "minLength": 1, "maxLength": 1000, "description": "Mandatory reason for override" },
      "expiresAt": { "type": "string", "format": "date-time", "description": "Optional expiration timestamp (must be future)" }
    }
  },
  "output": {
    "status": 201,
    "type": "object",
    "properties": {
      "overrideId": { "type": "string", "format": "uuid" },
      "tenantId": { "type": "string" },
      "dimensionKey": { "type": "string" },
      "overrideValue": { "type": "integer" },
      "quotaType": { "type": "string", "enum": ["hard", "soft"] },
      "graceMargin": { "type": "integer" },
      "justification": { "type": "string" },
      "expiresAt": { "type": ["string", "null"], "format": "date-time" },
      "status": { "type": "string", "const": "active" },
      "supersededOverrideId": { "type": ["string", "null"], "format": "uuid" },
      "createdAt": { "type": "string", "format": "date-time" },
      "createdBy": { "type": "string" }
    }
  },
  "errors": [
    { "status": 400, "code": "INVALID_DIMENSION_KEY", "description": "dimensionKey not found in quota_dimension_catalog" },
    { "status": 400, "code": "INVALID_OVERRIDE_VALUE", "description": "overrideValue is not an integer >= -1" },
    { "status": 400, "code": "JUSTIFICATION_REQUIRED", "description": "justification is empty or missing" },
    { "status": 400, "code": "GRACE_MARGIN_REQUIRED_FOR_SOFT", "description": "graceMargin missing when quotaType = soft" },
    { "status": 400, "code": "EXPIRATION_MUST_BE_FUTURE", "description": "expiresAt is in the past" },
    { "status": 404, "code": "TENANT_NOT_FOUND", "description": "tenantId does not exist" },
    { "status": 403, "code": "FORBIDDEN", "description": "Caller is not a superadmin" }
  ]
}
