{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "openapi-spec-updated-event",
  "title": "OpenApiSpecUpdatedEvent",
  "type": "object",
  "required": ["eventType", "timestamp", "tenantId", "workspaceId", "specVersion", "previousSpecVersion", "contentHash", "capabilityTags", "changeType"],
  "properties": {
    "eventType": { "type": "string", "const": "openapi.spec.updated" },
    "timestamp": { "type": "string", "format": "date-time" },
    "tenantId": { "type": "string", "format": "uuid" },
    "workspaceId": { "type": "string", "format": "uuid" },
    "specVersion": { "type": "string" },
    "previousSpecVersion": { "type": "string" },
    "contentHash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "capabilityTags": { "type": "array", "items": { "type": "string" } },
    "changeType": { "type": "string", "enum": ["MAJOR", "MINOR", "PATCH"] }
  }
}
