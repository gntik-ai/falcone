{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "mongo-capture-lifecycle-event",
  "type": "object",
  "required": ["specversion", "type", "source", "id", "time", "tenantid", "workspaceid", "data"],
  "properties": {
    "specversion": { "const": "1.0" },
    "type": {
      "enum": [
        "console.mongo-capture.capture-enabled",
        "console.mongo-capture.capture-disabled",
        "console.mongo-capture.capture-errored",
        "console.mongo-capture.capture-paused",
        "console.mongo-capture.capture-resumed",
        "console.mongo-capture.quota-exceeded",
        "console.mongo-capture.oversized-event",
        "console.mongo-capture.stream-invalidated"
      ]
    },
    "source": { "type": "string" },
    "id": { "type": "string", "format": "uuid" },
    "time": { "type": "string", "format": "date-time" },
    "tenantid": { "type": "string" },
    "workspaceid": { "type": "string" },
    "data": {
      "type": "object",
      "required": ["capture_id", "tenant_id", "workspace_id", "actor_identity", "action"],
      "properties": {
        "capture_id": { "type": ["string", "null"] },
        "tenant_id": { "type": ["string", "null"] },
        "workspace_id": { "type": ["string", "null"] },
        "actor_identity": { "type": ["string", "null"] },
        "action": { "type": "string" },
        "collection_name": { "type": "string" },
        "database_name": { "type": "string" },
        "before_state": { "type": ["object", "null"] },
        "after_state": { "type": ["object", "null"] },
        "request_id": { "type": ["string", "null"] },
        "error_detail": {}
      }
    }
  }
}
