{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "console-workflow-job-status",
  "title": "Console Workflow Job Status",
  "definitions": {
    "affectedResource": {
      "type": "object",
      "required": ["type", "id"],
      "properties": {
        "type": { "type": "string" },
        "id": { "type": "string" }
      },
      "additionalProperties": true
    },
    "auditFields": {
      "type": "object",
      "required": ["workflowId", "actor", "tenantId", "timestamp", "affectedResources", "outcome"],
      "properties": {
        "workflowId": { "type": "string" },
        "actor": { "type": "string" },
        "tenantId": { "type": "string" },
        "workspaceId": { "type": ["string", "null"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "affectedResources": {
          "type": "array",
          "items": { "$ref": "#/definitions/affectedResource" }
        },
        "outcome": { "type": "string", "enum": ["succeeded", "failed"] }
      },
      "additionalProperties": true
    },
    "errorSummary": {
      "type": "object",
      "required": ["code", "message"],
      "properties": {
        "code": { "type": "string" },
        "message": { "type": "string" },
        "failedStep": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    }
  },
  "type": "object",
  "required": ["jobRef", "workflowId", "idempotencyKey", "status", "createdAt", "updatedAt"],
  "properties": {
    "jobRef": { "type": "string" },
    "workflowId": { "type": "string" },
    "idempotencyKey": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["pending", "running", "succeeded", "failed"]
    },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "result": { "type": ["object", "null"] },
    "errorSummary": {
      "oneOf": [
        { "$ref": "#/definitions/errorSummary" },
        { "type": "null" }
      ]
    },
    "auditFields": {
      "oneOf": [
        { "$ref": "#/definitions/auditFields" },
        { "type": "null" }
      ]
    }
  },
  "additionalProperties": true
}
