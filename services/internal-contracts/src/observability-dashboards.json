{
  "version": "2026-03-28",
  "scope": "US-OBS-01-T02",
  "system": "in-falcone-observability-plane",
  "source_metrics_contract": "2026-03-28",
  "hierarchy": {
    "canonical_order": [
      "global",
      "tenant",
      "workspace"
    ],
    "drilldown_rules": [
      {
        "from": "global",
        "to": "tenant",
        "requires": [
          "platform_operator_access",
          "target_tenant_id"
        ],
        "semantics": "Global dashboard drilldown may target a tenant view when the actor has platform-wide authority and a concrete tenant context."
      },
      {
        "from": "tenant",
        "to": "workspace",
        "requires": [
          "tenant_dashboard_access",
          "target_workspace_id",
          "workspace_belongs_to_tenant"
        ],
        "semantics": "Tenant dashboard drilldown may target a workspace view only when the workspace belongs to the current tenant scope."
      }
    ],
    "forbidden_transitions": [
      {
        "from": "workspace",
        "to": "tenant",
        "reason": "Workspace views do not widen scope; operators must re-enter the tenant view through an authorized tenant context."
      },
      {
        "from": "workspace",
        "to": "global",
        "reason": "Workspace views cannot widen to platform scope because presentation-level navigation must preserve least privilege."
      }
    ]
  },
  "mandatory_health_dimensions": [
    {
      "id": "availability",
      "metric_category": "availability",
      "description": "Normalized subsystem availability posture derived from component_up and companion health projections."
    },
    {
      "id": "errors",
      "metric_category": "errors",
      "description": "Normalized error posture derived from component_operation_errors_total."
    },
    {
      "id": "latency",
      "metric_category": "latency",
      "description": "Normalized latency posture derived from component_operation_duration_seconds."
    },
    {
      "id": "throughput",
      "metric_category": "throughput",
      "description": "Normalized throughput posture derived from component_operations_total."
    },
    {
      "id": "collection_freshness",
      "metric_category": "collection_health",
      "description": "Collection freshness and lag posture derived from observability collection health and lag signals."
    }
  ],
  "health_states": {
    "allowed_values": [
      "healthy",
      "degraded",
      "unknown",
      "stale",
      "unavailable",
      "inherited"
    ],
    "state_rules": [
      {
        "state": "stale",
        "meaning": "Telemetry freshness is outside the subsystem max staleness window or collection has failed recently.",
        "must_not_be_reported_as": "healthy"
      },
      {
        "state": "unknown",
        "meaning": "No reliable current posture can be inferred because telemetry is missing or incomplete."
      },
      {
        "state": "inherited",
        "meaning": "The visible degradation is inherited from a broader tenant or platform scope rather than proven workspace-local."
      }
    ]
  },
  "collection_freshness": {
    "telemetry_contract": {
      "health_metric": "in_falcone_observability_collection_health",
      "failure_counter": "in_falcone_observability_collection_failures_total",
      "lag_metric": "in_falcone_observability_collection_lag_seconds"
    },
    "semantics": [
      "Dashboards must surface freshness as a first-class health dimension for every scope.",
      "A widget with stale or failed collection cannot be presented as current healthy posture.",
      "Collection lag should be interpreted against the subsystem max_staleness_seconds defined by the observability metrics stack contract."
    ]
  },
  "authorization_and_traceability": {
    "requirements": [
      "Dashboard access must preserve actor identity, correlation context, and requested dashboard scope.",
      "Tenant dashboards require tenant-bounded authorization and must reject cross-tenant access.",
      "Workspace dashboards require both tenant-bounded authorization and proof that the workspace belongs to the tenant context.",
      "Scope requests and drilldowns must remain attributable to the requesting actor for audit purposes.",
      "Tenant and workspace views may reference upstream platform dependency states only in a redacted, non-comparative form that does not leak other-tenant details."
    ],
    "audit_context_fields": [
      "actor_id",
      "dashboard_scope",
      "tenant_id",
      "workspace_id",
      "correlation_id"
    ]
  },
  "scope_aliases": {
    "global": {
      "dashboard_scope": "global",
      "metric_scope": "platform"
    },
    "tenant": {
      "dashboard_scope": "tenant",
      "metric_scope": "tenant"
    },
    "workspace": {
      "dashboard_scope": "workspace",
      "metric_scope": "workspace"
    }
  },
