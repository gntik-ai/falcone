{
  "version": "2026-03-24",
  "scope": "US-ARC-03",
  "system": "in-atelier-contextual-authorization",
  "contracts": {
    "security_context": {
      "owner": "services/internal-contracts",
      "version": "2026-03-24",
      "required_fields": [
        "actor",
        "tenant_id",
        "workspace_id",
        "plan_id",
        "scopes",
        "effective_roles",
        "correlation_id"
      ],
      "versioning": "The normalized context envelope evolves additively while preserving actor, tenant, workspace, plan, scopes, effective roles, and correlation semantics.",
      "error_classes": [
        "missing_context",
        "ambiguous_context",
        "cross_tenant_violation",
        "workspace_context_required"
      ]
    },
    "authorization_decision": {
      "owner": "services/internal-contracts",
      "version": "2026-03-24",
      "required_fields": [
        "decision_id",
        "resource_type",
        "action",
        "effect",
        "reason",
        "tenant_id",
        "workspace_id",
        "correlation_id",
        "effective_roles",
        "matched_policies"
      ],
      "versioning": "Decision envelopes keep stable effect and reason semantics so control-plane, adapters, and audit consumers can evolve independently.",
      "error_classes": [
        "insufficient_scope",
        "cross_tenant_violation",
        "delegation_violation",
        "quota_exceeded"
      ]
    },
    "context_projection": {
      "owner": "services/internal-contracts",
      "version": "2026-03-24",
      "required_fields": [
        "target",
        "tenant_id",
        "workspace_id",
        "plan_id",
        "correlation_id",
        "effective_roles",
        "scopes",
        "delegation_chain"
      ],
      "versioning": "Projection metadata may add targets, but correlation, tenant/workspace bindings, and delegated scope semantics must remain explicit and lossless.",
      "error_classes": [
        "projection_loss",
        "redaction_violation"
      ]
    },
    "negative_authorization_case": {
      "owner": "tests/reference",
      "version": "2026-03-24",
      "required_fields": [
        "id",
        "surface",
        "category",
        "expected_effect",
        "summary"
      ],
      "versioning": "Negative coverage grows by adding new abuse cases while preserving baseline cross-tenant and privilege-escalation protections.",
      "error_classes": [
        "missing_negative_coverage",
        "unsafe_surface_gap"
      ]
    }
  },
  "role_catalog": {
    "platform": [
      {
        "id": "platform_admin",
        "scope": "platform",
        "inherits": [],
        "summary": "Full cross-tenant control-plane operations with explicit audit obligations."
      },
      {
        "id": "platform_operator",
        "scope": "platform",
        "inherits": [],
        "summary": "Platform-wide operational visibility and remediation without tenant data administration."
      },
      {
        "id": "platform_auditor",
        "scope": "platform",
        "inherits": [],
        "summary": "Read-only cross-tenant audit and compliance visibility."
      }
    ],
    "tenant": [
      {
        "id": "tenant_admin",
        "scope": "tenant",
        "inherits": [],
        "summary": "Tenant-wide administration excluding platform-only operations."
      },
      {
        "id": "tenant_operator",
        "scope": "tenant",
        "inherits": [],
        "summary": "Operate tenant workloads and inspect tenant usage without membership or billing administration."
      },
      {
        "id": "tenant_billing_admin",
        "scope": "tenant",
        "inherits": [],
        "summary": "Manage plan and quota workflows without workspace runtime administration."
      },
      {
        "id": "auditor",
        "scope": "tenant",
        "inherits": [],
        "summary": "Read-only tenant audit and evidence review."
      }
    ],
    "workspace": [
      {
        "id": "workspace_admin",
        "scope": "workspace",
        "inherits": [],
        "summary": "Workspace-wide administration for resources owned by one workspace."
      },
      {
        "id": "workspace_developer",
        "scope": "workspace",
        "inherits": [],
        "summary": "Create and modify application-facing resources in one workspace."
      },
      {
        "id": "workspace_operator",
        "scope": "workspace",
        "inherits": [],
        "summary": "Operate deployed workspace resources and inspect runtime state."
      },
      {
        "id": "workspace_auditor",
        "scope": "workspace",
        "inherits": [],
        "summary": "Review audit evidence and configuration posture for one workspace."
      },
      {
        "id": "workspace_viewer",
        "scope": "workspace",
        "inherits": [],
        "summary": "Read-only visibility for workspace metadata and runtime inventory."
      }
    ]
  },
  "security_context": {
    "actor_types": [
      {
        "id": "human_user",
        "credential_sources": [
          "keycloak_oidc"
        ],
        "required_claims": [
          "sub",
          "scope"
        ],
        "optional_claims": [
          "email",
          "name",
          "tenant_memberships",
          "workspace_memberships",
          "tenant_id",
          "workspace_id",
          "plan_id",
          "tenant_realm",
          "workspace_roles"
        ]
      },
      {
        "id": "service_workload",
        "credential_sources": [
          "keycloak_client_credentials",
          "signed_service_token"
        ],
        "required_claims": [
          "client_id",
          "scope"
        ],
        "optional_claims": [
          "tenant_bindings",
          "delegation_chain",
          "tenant_id",
          "workspace_id",
          "plan_id",
          "service_account_id",
          "tenant_realm"
        ]
      },
      {
        "id": "platform_break_glass",
        "credential_sources": [
          "keycloak_oidc"
        ],
        "required_claims": [
          "sub",
          "scope",
          "reason_code"
        ],
        "optional_claims": [
          "ticket_ref"
        ]
      }
    ],
    "required_fields": [
      "actor",
      "tenant_id",
      "workspace_id",
      "plan_id",
      "scopes",
      "effective_roles",
      "correlation_id"
    ],
    "optional_fields": [
      "delegation_chain",
      "quota_snapshot",
      "resource_ownership",
      "request_id",
      "idempotency_key",
      "identity_realm",
      "client_id"
    ],
    "resolution_order": [
      "Authenticate the actor and classify the credential source.",
      "Resolve the requested tenant and verify the actor is explicitly bound to that tenant unless a platform role authorizes cross-tenant access.",
      "Resolve the requested workspace and verify the workspace belongs to the resolved tenant before any resource lookup proceeds.",
      "Merge platform, tenant, and workspace role bindings into one effective role set limited to the resolved tenant/workspace boundary.",
      "Intersect effective roles with granted scopes and tenant-plan guardrails before making an allow decision.",
      "Emit one correlation_id reused by control-plane handlers, internal contracts, provider adapters, events, and audit records.",
      "Separate platform-realm console identities from tenant-realm or federated tenant identities before computing effective roles or downstream projections.",
      "Project tenant_id, workspace_id, plan_id, and tenant_realm through Keycloak protocol mappers so gateway and downstream services can verify scope without rehydrating raw provider state."
    ],
    "default_denials": [
      "deny_missing_tenant_binding",
      "deny_workspace_outside_tenant",
      "deny_cross_tenant_access_without_explicit_platform_role",
      "deny_delegation_scope_expansion",
      "deny_break_glass_without_reason"
    ]
  },
  "enforcement_surfaces": [
    {
      "id": "control_api",
      "planes": [
        "control_plane"
      ],
      "request_bindings": {
        "tenant_sources": [
          "path",
          "body"
        ],
        "workspace_sources": [
          "path",
          "body",
          "header:x-workspace-id"
        ],
        "correlation_sources": [
          "header:x-correlation-id",
          "generated"
        ]
      },
      "required_context_fields": [
        "actor",
        "tenant_id",
        "workspace_id",
        "plan_id",
        "scopes",
        "effective_roles",
        "correlation_id"
      ],
      "decision_contract": "authorization_decision",
      "quota_stage": "preflight",
      "audit_mode": "accept_and_reject"
    },
    {
      "id": "data_api",
      "planes": [
        "data_plane"
      ],
      "request_bindings": {
        "tenant_sources": [
          "session",
          "connection"
        ],
        "workspace_sources": [
          "session",
          "sql_setting:app.workspace_id"
        ],
        "correlation_sources": [
          "header:x-correlation-id",
          "generated"
        ]
      },
      "required_context_fields": [
        "actor",
        "tenant_id",
        "workspace_id",
        "plan_id",
        "scopes",
        "effective_roles",
        "correlation_id"
      ],
      "decision_contract": "authorization_decision",
      "quota_stage": "preflight_and_row_filter",
      "audit_mode": "denials_and_admin_mutations"
    },
    {
      "id": "functions_runtime",
      "planes": [
        "functions_plane"
      ],
      "request_bindings": {
        "tenant_sources": [
          "activation_annotation",
          "request_header"
        ],
        "workspace_sources": [
          "activation_annotation",
          "request_header"
        ],
        "correlation_sources": [
          "activation_annotation",
          "header:x-correlation-id"
        ]
      },
      "required_context_fields": [
        "actor",
        "tenant_id",
        "workspace_id",
        "plan_id",
        "scopes",
        "effective_roles",
        "correlation_id"
      ],
      "decision_contract": "authorization_decision",
      "quota_stage": "invocation_preflight",
      "audit_mode": "activations_and_denials"
    },
    {
      "id": "event_bus",
      "planes": [
        "event_plane"
      ],
      "request_bindings": {
        "tenant_sources": [
          "message_header:tenant-id",
          "acl_subject"
        ],
        "workspace_sources": [
          "message_header:workspace-id",
          "acl_subject"
        ],
        "correlation_sources": [
          "message_header:correlation-id"
        ]
      },
      "required_context_fields": [
        "actor",
        "tenant_id",
        "workspace_id",
        "plan_id",
        "scopes",
        "effective_roles",
        "correlation_id"
      ],
      "decision_contract": "authorization_decision",
      "quota_stage": "publish_or_consume_preflight",
      "audit_mode": "topic_admin_and_denials"
    },
    {
      "id": "object_storage",
      "planes": [
        "storage_plane"
      ],
      "request_bindings": {
        "tenant_sources": [
          "bucket_policy_tag",
          "presign_context"
        ],
        "workspace_sources": [
          "bucket_policy_tag",
          "presign_context"
        ],
        "correlation_sources": [
          "presign_context",
          "header:x-correlation-id"
        ]
      },
      "required_context_fields": [
        "actor",
        "tenant_id",
        "workspace_id",
        "plan_id",
        "scopes",
        "effective_roles",
        "correlation_id"
      ],
      "decision_contract": "authorization_decision",
      "quota_stage": "presign_and_write_preflight",
      "audit_mode": "bucket_admin_and_denials"
    }
