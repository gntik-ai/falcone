  "resource_semantics": [
    {
      "resource_type": "tenant",
      "parent_scope": "platform",
      "workspace_scoped": false,
      "ownership_model": "tenant-owned collaboration boundary with owner-mediated transfer and audited platform override",
      "membership_bindings": [
        "tenant_roles"
      ],
      "delegable_actions": [
        "tenant.members.manage",
        "tenant.workspaces.create",
        "tenant.usage.read",
        "tenant.invitations.manage",
        "tenant.role_mappings.manage",
        "tenant.ownership.transfer",
        "tenant.ownership_transfers.read",
        "tenant.effective_permissions.read",
        "tenant.effective_permissions.recalculate"
      ],
      "forbidden_actions": [
        "cross_tenant.impersonate",
        "delegation.scope.expand"
      ]
    },
    {
      "resource_type": "workspace",
      "parent_scope": "tenant",
      "workspace_scoped": true,
      "ownership_model": "tenant-owned workspace boundary with independently granted workspace memberships",
      "membership_bindings": [
        "workspace_roles"
      ],
      "delegable_actions": [
        "workspace.read",
        "workspace.update",
        "workspace.members.manage",
        "workspace.invitations.manage",
        "workspace.role_mappings.manage",
        "workspace.policy.manage",
        "workspace.effective_permissions.read",
        "workspace.audit.read",
        "workspace.effective_permissions.recalculate"
      ],
      "forbidden_actions": [
        "workspace.delete_without_tenant_admin",
        "cross_workspace_membership_reuse"
      ]
    },
    {
      "resource_type": "database",
      "parent_scope": "workspace",
      "workspace_scoped": true,
      "ownership_model": "workspace-owned data service",
      "membership_bindings": [
        "workspace_roles"
      ],
      "delegable_actions": [
        "database.read",
        "database.write",
        "database.rpc.execute"
      ],
      "forbidden_actions": [
        "database.admin_without_workspace_admin",
        "cross_workspace_connection_reuse",
        "database.admin_sql_without_explicit_confirmation",
        "database.admin_sql_from_automation"
      ]
    },
    {
      "resource_type": "bucket",
      "parent_scope": "workspace",
      "workspace_scoped": true,
      "ownership_model": "workspace-owned storage surface",
      "membership_bindings": [
        "workspace_roles"
      ],
      "delegable_actions": [
        "bucket.read",
        "bucket.write"
      ],
      "forbidden_actions": [
        "bucket.admin_without_workspace_admin",
        "presign_outside_workspace_context"
      ]
    },
    {
