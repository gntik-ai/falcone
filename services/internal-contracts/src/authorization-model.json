  "propagation_targets": [
    {
      "target": "control_api_command",
      "required_fields": [
        "tenant_id",
        "workspace_id",
        "plan_id",
        "correlation_id",
        "effective_roles",
        "scopes",
        "delegation_chain",
        "authorization_decision_id"
      ],
      "redacted_fields": [
        "quota_snapshot"
      ],
      "reason": "Public handlers must normalize one context envelope before emitting internal commands."
    },
    {
      "target": "provisioning_request",
      "required_fields": [
        "tenant_id",
        "workspace_id",
        "plan_id",
        "correlation_id",
        "effective_roles",
        "scopes",
        "authorization_decision_id"
      ],
      "redacted_fields": [
        "credentials",
        "raw_tokens"
      ],
      "reason": "Orchestration steps must preserve the same tenant/workspace decision used at the edge."
    },
    {
      "target": "adapter_call",
      "required_fields": [
        "tenant_id",
        "workspace_id",
        "plan_id",
        "correlation_id",
        "effective_roles",
        "scopes",
        "authorization_decision_id"
      ],
      "redacted_fields": [
