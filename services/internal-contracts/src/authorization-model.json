  "propagation_targets": [
    {
      "target": "control_api_command",
      "required_fields": [
        "tenant_id",
        "workspace_id",
        "plan_id",
        "correlation_id",
        "effective_roles",
        "scopes",
        "delegation_chain",
        "authorization_decision_id"
      ],
      "redacted_fields": [
        "quota_snapshot"
      ],
      "reason": "Public handlers must normalize one context envelope before emitting internal commands."
    },
    {
      "target": "provisioning_request",
      "required_fields": [
        "tenant_id",
        "workspace_id",
        "plan_id",
        "correlation_id",
        "effective_roles",
        "scopes",
        "authorization_decision_id"
      ],
      "redacted_fields": [
        "credentials",
        "raw_tokens"
      ],
      "reason": "Orchestration steps must preserve the same tenant/workspace decision used at the edge."
    },
    {
      "target": "adapter_call",
      "required_fields": [
        "tenant_id",
        "workspace_id",
        "plan_id",
        "correlation_id",
        "effective_roles",
        "scopes",
        "authorization_decision_id"
      ],
      "redacted_fields": [
        "raw_tokens",
        "break_glass_reason"
      ],
      "reason": "Adapter ACLs and provider metadata need the resolved context without leaking credential internals."
    },
    {
      "target": "audit_record",
      "required_fields": [
        "tenant_id",
        "workspace_id",
        "correlation_id",
        "authorization_decision_id",
        "effective_roles",
        "delegation_chain"
      ],
      "redacted_fields": [
        "credentials",
        "raw_tokens"
      ],
      "reason": "Audit evidence must reconstruct why a decision was allowed or denied without storing raw credentials."
    },
    {
      "target": "kafka_headers",
      "required_fields": [
        "tenant_id",
        "workspace_id",
        "correlation_id",
        "authorization_decision_id"
      ],
      "redacted_fields": [
        "effective_roles"
      ],
      "reason": "Event consumers need routing-safe identity while role details stay in audit and internal contracts."
    },
    {
      "target": "openwhisk_activation",
      "required_fields": [
        "tenant_id",
        "workspace_id",
        "plan_id",
        "correlation_id",
        "authorization_decision_id"
      ],
      "redacted_fields": [
        "raw_tokens",
        "delegation_chain"
      ],
      "reason": "Function activations need enough context for scoped invocation and observability while minimizing token leakage."
    },
    {
      "target": "storage_presign_context",
      "required_fields": [
        "tenant_id",
        "workspace_id",
        "plan_id",
        "correlation_id",
        "authorization_decision_id"
      ],
      "redacted_fields": [
        "effective_roles",
        "raw_tokens"
      ],
      "reason": "Presigned URL issuance and multipart completion must stay tenant/workspace-bound even if the client retries later."
    },
    {
      "target": "console_backend_activation",
      "carrier": "activation_annotation",
      "fields": [
        "actor",
        "tenant_id",
        "workspace_id",
        "correlation_id",
        "initiating_surface"
      ],
      "required_fields": [
        "tenant_id",
        "workspace_id",
        "correlation_id",
        "initiating_surface"
      ],
      "reason": "Console backend activations must preserve actor, tenant/workspace scope, correlation, and initiating surface attribution for runtime enforcement and audit traceability.",
      "redacted_fields": []
    },
    {
      "target": "definition_import_context",
      "carrier": "validated_attestation",
      "required_fields": [
        "tenant_id",
        "workspace_id",
        "correlation_id",
        "effective_roles",
        "scopes",
        "import_operation",
        "visibility_policy"
      ],
      "redacted_fields": [
        "bundle_payload"
      ],
      "reason": "Function definition import/export flows must keep scope, operator intent, and visibility policy explicit across command handling."
    },
    {
      "target": "audit_query_context",
      "required_fields": [
        "actor",
        "correlation_id",
        "query_scope"
      ],
      "optional_fields": [
        "tenant_id",
        "workspace_id",
        "action_type_filter",
        "filter_set_hash"
      ],
      "redacted_fields": [
        "raw_tokens"
      ],
      "reason": "Audit queries must stay bound to the caller scope while allowing tenant-only or workspace-specific query envelopes without leaking credential internals."
    }
  ],
  "negative_scenarios": [
    {
      "id": "AUTHZ-XTEN-001",
      "surface": "control_api",
      "category": "cross_tenant",
      "expected_effect": "deny",
      "summary": "A tenant-scoped actor cannot request a resource in another tenant even if the workspace slug matches."
    },
    {
      "id": "AUTHZ-XWS-002",
      "surface": "data_api",
      "category": "workspace_mismatch",
      "expected_effect": "deny",
      "summary": "A valid tenant binding does not authorize access to another workspace inside the same tenant."
    },
    {
      "id": "AUTHZ-DEL-003",
      "surface": "functions_runtime",
      "category": "delegation_escalation",
      "expected_effect": "deny",
      "summary": "Delegated function invocations cannot add scopes or roles absent from the delegation chain."
    },
    {
      "id": "AUTHZ-ACL-004",
      "surface": "object_storage",
      "category": "storage_acl_bypass",
      "expected_effect": "deny",
      "summary": "Presigned URL issuance fails when bucket policy or workspace binding does not match the resolved context."
    },
    {
      "id": "AUTHZ-EVT-005",
      "surface": "event_bus",
      "category": "event_replay",
      "expected_effect": "deny",
      "summary": "Replay or publish attempts with mismatched tenant/workspace headers are rejected before provider ACLs are reached."
    },
    {
      "id": "AUTHZ-PLN-006",
      "surface": "control_api",
      "category": "plan_guardrail",
      "expected_effect": "deny",
      "summary": "Actions outside the tenant plan, such as restricted workspace capacity, are denied even when the actor has a role grant."
    },
    {
      "id": "AUTHZ-IAM-007",
      "category": "identity_boundary",
      "surface": "control_api",
      "expected_effect": "deny",
      "summary": "Tenant-realm tokens cannot impersonate platform-realm console users or rotate service-account credentials outside their workspace namespace."
    },
    {
      "id": "AUTHZ-INV-008",
      "surface": "control_api",
      "category": "invitation_replay",
      "expected_effect": "deny",
      "summary": "Expired or revoked invitations cannot be accepted again, even when a stale token is replayed inside the same tenant."
    },
    {
      "id": "AUTHZ-SVC-009",
      "surface": "data_api",
      "category": "service_account_boundary",
      "expected_effect": "deny",
      "summary": "Workspace service-account identities cannot administer credentials or access managed resources outside the policy bindings of their own workspace."
    },
    {
      "id": "AUTHZ-OWN-009",
      "surface": "control_api",
      "category": "ownership_transfer",
      "expected_effect": "deny",
      "summary": "Tenant ownership transfer is denied unless the acting owner initiates it, the designated target accepts it, and effective permissions are recalculated inside the same tenant boundary."
    },
    {
      "id": "AUTHZ-FN-CON-001",
      "surface": "functions_runtime",
      "category": "console_backend_cross_scope",
      "expected_effect": "deny",
      "summary": "A console backend workspace service account cannot invoke or affect resources outside its authorized tenant or workspace scope."
    },
    {
      "id": "AUTHZ-FN-CON-002",
      "surface": "functions_runtime",
      "category": "console_backend_missing_scope",
      "expected_effect": "deny",
      "summary": "A console backend activation without tenant_id or workspace_id annotation must be rejected before dispatch."
    },
    {
      "id": "AUTHZ-FN-IMP-001",
      "surface": "functions_runtime",
      "category": "definition_import_cross_scope",
      "expected_effect": "deny",
      "summary": "A function definition import must be denied when the bundle tenant or workspace scope does not match the caller scope."
    },
    {
      "id": "AUTHZ-FN-IMP-002",
      "surface": "functions_runtime",
      "category": "definition_import_visibility_policy",
      "expected_effect": "deny",
      "summary": "A function definition import must be denied when a requested web-action visibility value falls outside the governed public/private policy set."
    },
    {
      "id": "AUTHZ-FN-AUD-001",
      "description": "Caller queries audit records outside their authorized tenant — denied without revealing foreign records.",
      "surface": "control_api",
      "category": "cross_tenant",
      "expected_effect": "deny",
      "summary": "Audit query outside the caller tenant is denied without revealing foreign records."
    },
    {
      "id": "AUTHZ-FN-AUD-002",
      "description": "Caller queries audit records outside their authorized workspace — denied without revealing foreign records.",
      "surface": "control_api",
      "category": "cross_workspace",
      "expected_effect": "deny",
      "summary": "Audit query outside the caller workspace is denied without revealing foreign records."
    },
    {
      "id": "AUTHZ-FN-AUD-003",
      "description": "Non-superadmin calls the coverage report endpoint — denied with HTTP 403.",
      "surface": "control_api",
      "category": "privilege_escalation",
      "expected_effect": "deny",
      "summary": "Coverage report access is denied for callers that are not superadmins."
    },
    {
      "id": "AUTHZ-FN-AUD-004",
      "description": "Audit query limit exceeds the bounded maximum — rejected before query execution.",
      "surface": "control_api",
      "category": "request_validation",
      "expected_effect": "deny",
      "summary": "Audit query limits above the bounded maximum are rejected before query execution."
    }
  ]
}
