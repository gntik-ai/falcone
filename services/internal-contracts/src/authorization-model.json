        ],
        "workspace_sources": [
          "message_header:workspace-id",
          "acl_subject"
        ],
        "correlation_sources": [
          "message_header:correlation-id"
        ]
      },
      "required_context_fields": [
        "actor",
        "tenant_id",
        "workspace_id",
        "plan_id",
        "scopes",
        "effective_roles",
        "correlation_id"
      ],
      "decision_contract": "authorization_decision",
      "quota_stage": "publish_or_consume_preflight",
      "audit_mode": "topic_admin_and_denials"
    },
    {
      "id": "object_storage",
      "planes": [
        "storage_plane"
      ],
      "request_bindings": {
