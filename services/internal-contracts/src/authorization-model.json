  "resource_semantics": [
    {
      "resource_type": "tenant",
      "parent_scope": "platform",
      "workspace_scoped": false,
      "ownership_model": "tenant-owned with audited platform override",
      "membership_bindings": [
        "tenant_roles"
      ],
      "delegable_actions": [
        "tenant.members.manage",
        "tenant.workspaces.create",
        "tenant.usage.read"
      ],
      "forbidden_actions": [
        "cross_tenant.impersonate",
        "delegation.scope.expand"
      ]
    },
    {
      "resource_type": "workspace",
      "parent_scope": "tenant",
      "workspace_scoped": true,
      "ownership_model": "tenant-owned workspace with workspace-level delegates",
      "membership_bindings": [
        "tenant_roles",
        "workspace_roles"
      ],
      "delegable_actions": [
        "workspace.read",
        "workspace.update",
