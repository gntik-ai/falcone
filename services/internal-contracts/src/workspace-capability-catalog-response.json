{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://falcone.internal/schemas/workspace-capability-catalog-response.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["workspaceId", "tenantId", "generatedAt", "catalogVersion", "capabilities"],
  "properties": {
    "workspaceId": { "type": "string", "minLength": 1 },
    "tenantId": { "type": "string", "minLength": 1 },
    "generatedAt": { "type": "string", "format": "date-time" },
    "catalogVersion": { "type": "string", "minLength": 1 },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/capability" }
    }
  },
  "$defs": {
    "example": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operationId", "label", "language", "code", "hasPlaceholderSecrets", "secretPlaceholderRef"],
      "properties": {
        "operationId": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "language": { "type": "string", "minLength": 1 },
        "code": { "type": "string", "minLength": 1 },
        "hasPlaceholderSecrets": { "type": "boolean" },
        "secretPlaceholderRef": { "type": "string", "minLength": 1 }
      }
    },
    "capabilityBase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "displayName", "category", "enabled", "status", "version", "dependencies", "examples"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "displayName": { "type": "string", "minLength": 1 },
        "category": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "enabled": { "type": "boolean" },
        "status": {
          "type": "string",
          "enum": ["active", "disabled", "provisioning", "deprovisioning"]
        },
        "version": { "type": "string", "minLength": 1 },
        "quota": { "type": "object", "additionalProperties": true },
        "dependencies": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "dependencyNote": { "type": "string", "minLength": 1 },
        "examples": {
          "type": "array",
          "items": { "$ref": "#/$defs/example" }
        },
        "enablementGuide": { "type": "string", "minLength": 1 }
      }
    },
    "capability": {
      "oneOf": [
        {
          "allOf": [
            { "$ref": "#/$defs/capabilityBase" },
            {
              "properties": {
                "enabled": { "const": true },
                "examples": { "type": "array", "minItems": 1 }
              }
            }
          ]
        },
        {
          "allOf": [
            { "$ref": "#/$defs/capabilityBase" },
            {
              "required": ["enablementGuide"],
              "properties": {
                "enabled": { "const": false },
                "examples": { "type": "array", "maxItems": 0 }
              }
            }
          ]
        }
      ]
    }
  }
}
