{
  "version": "2026-03-24",
  "scope": "US-IAM-02",
  "system": "in-atelier-public-api",
  "release": {
    "path_version": "v1",
    "header_version": "2026-03-24",
    "openapi_semver": "1.10.0"
  },
  "versioning": {
    "uri_prefix": "/v1",
    "discovery_route": "/v1/platform/route-catalog",
    "non_breaking_evolution": [
      "The URI major version remains pinned at /v1 while additive evolution is announced through the X-API-Version header.",
      "Gateway QoS, request hardening, and response-envelope improvements may add optional metadata and response codes within v1 when they preserve current semantics and authorization boundaries.",
      "Generated family contracts and the route catalog must be refreshed from the unified contract on every published change."
    ],
    "breaking_change_policy": [
      "Breaking request/response, authentication, or authorization changes require a new URI family such as /v2 and an explicit coexistence window.",
      "Deprecated routes remain cataloged with a sunset marker until the replacement family is published and documented.",
      "Gateway routing, family contracts, and published docs must all advertise the same deprecation and removal dates."
    ]
  },
  "shared_http": {
    "headers": {
      "api_version": {
        "name": "X-API-Version",
        "required": true,
        "current_value": "2026-03-24",
        "purpose": "Pins the non-breaking contract generation inside /v1."
      },
      "correlation_id": {
        "name": "X-Correlation-Id",
        "required": true,
        "purpose": "Carries one stable trace, audit, and orchestration identifier across gateway and internal services; the gateway preserves or backfills it for downstream continuity."
      },
      "idempotency_key": {
        "name": "Idempotency-Key",
        "required_for_methods": [
          "post",
          "put",
          "patch",
          "delete"
        ],
        "purpose": "Coalesces safe retries for mutating requests accepted by the gateway and critical create/provision flows."
      }
    },
    "pagination": {
      "style": "cursor",
      "limit_param": "page[size]",
      "cursor_param": "page[after]",
      "default_limit": 25,
      "max_limit": 200,
      "sort_param": "sort"
    },
    "filtering": {
      "search_param": "search",
      "filter_prefix": "filter[",
      "catalog_filters": [
        "family",
        "scope",
        "resourceType",
        "method",
        "audience",
        "visibility"
      ]
    },
    "errors": {
      "schema": "ErrorResponse",
      "required_fields": [
        "status",
        "code",
        "message",
        "detail",
        "requestId",
        "correlationId",
        "timestamp",
        "resource"
      ],
      "code_prefix": "GW_",
      "replay_header": "X-Idempotency-Replayed",
      "retryable_statuses": [
        429,
        502,
        503,
        504
      ]
    },
    "security": {
      "default_scheme": "bearerAuth",
      "default_authn": "Keycloak OIDC bearer token",
      "default_authz": "deny_by_default contextual authorization",
      "audit_mode": "accept_and_reject"
    },
    "qos": {
      "family_profiles": [
        "platform_control",
        "tenant_control",
        "workspace_control",
        "auth_control",
        "provisioning",
        "observability",
        "realtime"
      ],
      "enforced_at_gateway": [
        "rate_limit",
        "body_size",
        "header_validation",
        "timeouts",
        "retry_policy"
      ]
    }
  },
