{
  "version": "2026-03-28",
  "source_usage_contract": "2026-03-28",
  "source_quota_policy_contract": "2026-03-28",
  "source_threshold_alert_contract": "2026-03-28",
  "source_public_api_contract": "2026-03-26",
  "error_contract": {
    "http_status": 429,
    "error_code": "QUOTA_HARD_LIMIT_REACHED",
    "retryable": false,
    "required_fields": [
      "error_code",
      "dimension_id",
      "scope_type",
      "scope_id",
      "current_usage",
      "hard_limit",
      "blocking_action",
      "retryable",
      "message"
    ],
    "message_template": "Quota hard limit reached for {dimension_id} at {scope_type} scope {scope_id}."
  },
  "audit_contract": {
    "event_type": "quota.hard_limit.evaluated",
    "required_fields": [
      "eventType",
      "decision",
      "tenantId",
      "workspaceId",
      "dimensionId",
      "scopeType",
      "scopeId",
      "blockingAction",
      "currentUsage",
      "hardLimit",
      "evaluatedAt"
    ],
    "decision_values": [
      "allowed",
      "denied"
    ]
  },
  "enforcement_policy": {
    "scope_precedence": "strictest_breached_scope",
    "fail_closed_on_missing_evidence": true,
    "policy_refresh": "per_evaluation",
    "currently_implemented_surfaces": [
      "storage.bucket.create",
      "functions.action.create",
      "events.topic.create",
      "postgres.database.create",
      "postgres.role.create",
      "postgres.user.create",
      "postgres.schema.create",
      "postgres.table.create",
      "mongo.database.create",
      "mongo.collection.create"
    ]
  },
  "dimensions": [
    {
      "id": "api_requests",
      "source_dimensions": [
        "api_requests"
      ],
      "scope_types": [
        "tenant",
        "workspace"
      ],
      "blocking_mode": "request_admission"
    },
    {
      "id": "serverless_functions",
      "source_dimensions": [
