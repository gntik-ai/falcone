{
  "version": "2026-03-28",
  "scope": "US-OBS-01-T03",
  "system": "in-falcone-observability-plane",
  "source_metrics_contract": "2026-03-28",
  "source_dashboard_contract": "2026-03-28",
  "principles": [
    "Liveness, readiness, and health are distinct operational concepts and must not be collapsed into one generic status.",
    "Component health outputs stay internal and operational; they do not create a new public API commitment.",
    "Probe results must be safe for shared operational use through normalized, redacted dependency detail and explicit audit context.",
    "Probe outcomes must project into the same observability plane and dashboard semantics already defined for the platform."
  ],
  "probe_types": [
    {
      "id": "liveness",
      "display_name": "Liveness",
      "purpose": "Indicates whether the component runtime is alive enough to avoid dead-process restart loops.",
      "primary_audience": "orchestration",
      "allowed_statuses": [
        "live",
        "dead",
        "unknown"
      ],
      "dependency_failure_behavior": "Dependency loss alone should not imply dead liveness unless the runtime itself cannot continue functioning.",
      "stale_behavior": "Missing recent liveness evaluation is reported as unknown rather than assumed healthy."
    },
    {
      "id": "readiness",
      "display_name": "Readiness",
      "purpose": "Indicates whether the component can safely serve workload or continue participating in platform traffic right now.",
      "primary_audience": "orchestration_and_operations",
      "allowed_statuses": [
        "ready",
        "not_ready",
        "degraded",
        "unknown"
      ],
      "dependency_failure_behavior": "Dependency loss may make a component not_ready or degraded without implying dead liveness.",
      "stale_behavior": "Missing recent readiness evaluation is reported as unknown and must not be routed as current ready state."
    },
    {
      "id": "health",
      "display_name": "Health",
      "purpose": "Indicates the broader operational posture, including degraded-but-serving and dependency-inherited states.",
      "primary_audience": "operations",
      "allowed_statuses": [
        "healthy",
        "degraded",
        "unavailable",
        "unknown",
        "stale",
        "inherited"
      ],
      "dependency_failure_behavior": "Dependency failures may degrade health without requiring the component to be unavailable.",
      "stale_behavior": "Stale health evidence must be represented explicitly as stale, not healthy."
    }
  ],
  "status_model": {
    "aggregate_rules": {
      "liveness": "Platform liveness is dead when any required component is dead, unknown when no component is dead but at least one is unknown, otherwise live.",
      "readiness": "Platform readiness is not_ready when any required component is not_ready, degraded when none are not_ready but at least one is degraded, unknown when freshness is insufficient, otherwise ready.",
      "health": "Platform health is unavailable when any required component is unavailable, degraded when any required component is degraded, stale when evidence is stale, unknown when evidence is incomplete, otherwise healthy."
    },
    "stale_probe_window_seconds": 120,
    "allowed_dependency_outcomes": [
      "healthy",
      "degraded",
      "unavailable",
      "unknown",
      "masked"
    ]
  },
  "response_contracts": {
    "component_probe_result": {
      "version": "2026-03-28",
      "required_fields": [
        "component_id",
        "probe_type",
        "status",
        "observed_at",
        "summary",
        "correlation_id",
        "evidence_freshness_seconds"
      ],
      "optional_sections": [
        "dependencies",
        "scope_context",
        "metric_projection",
        "redaction",
        "audit_context"
      ],
      "versioning": "Breaking field removals or status renames require a new contract version; additive dependency metadata remains backwards compatible.",
      "error_classes": [
        "probe_target_unreachable",
        "probe_dependency_unavailable",
        "probe_dependency_masked",
        "probe_result_stale",
        "probe_scope_not_authorized"
      ]
    },
    "platform_probe_rollup": {
      "version": "2026-03-28",
      "required_fields": [
        "probe_type",
        "status",
        "observed_at",
        "component_results",
        "correlation_id"
      ],
      "versioning": "Rollup fields remain additive; the aggregate status semantics stay stable within the current contract version.",
      "error_classes": [
        "rollup_component_missing",
        "rollup_result_stale",
        "rollup_component_contract_mismatch"
      ]
    }
  },
  "audit_context": {
    "required_fields": [
      "actor_id",
      "probe_type",
      "component_id",
      "dashboard_scope",
      "tenant_id",
      "workspace_id",
      "correlation_id"
    ],
    "rules": [
      "Aggregate platform probes may omit tenant_id and workspace_id when no narrower scope is requested.",
      "Per-component operational views must preserve the requested component_id and probe_type in audit context.",
      "Tenant/workspace-scoped probe projections must reject cross-tenant or mismatched workspace context."
    ]
  },
  "masking_policy": {
    "forbidden_exposed_fields": [
      "password",
      "secret",
      "token",
      "authorization_header",
      "connection_string",
      "raw_hostname",
      "raw_endpoint",
      "object_key",
      "raw_topic_name"
    ],
    "normalized_error_classes": [
      "dependency_timeout",
      "dependency_auth_failed",
      "dependency_unreachable",
      "dependency_backpressure",
      "dependency_consistency_gap",
      "dependency_state_masked"
    ],
    "rules": [
      "Dependency details may expose stable component-local identifiers but not credentials or raw infrastructure coordinates.",
      "Tenant/workspace operational views must use inherited or masked summaries when narrower detail is not safely attributable.",
      "Masked dependency failures must remain distinguishable from healthy dependencies so operators can see that information was intentionally withheld."
    ]
  },
  "observability_projection": {
    "status_metric": "in_falcone_component_probe_status",
    "duration_metric": "in_falcone_component_probe_duration_seconds",
    "failure_counter": "in_falcone_component_probe_failures_total",
    "required_labels": [
      "environment",
      "subsystem",
      "metric_scope",
      "collection_mode",
      "probe_type",
      "exposure_kind"
    ],
    "status_value_model": {
      "success_value": 1,
      "failure_value": 0,
      "unknown_value": -1
    },
    "rules": [
      "Probe outcomes project into the common observability plane and remain queryable per subsystem and probe type.",
      "Tenant/workspace-scoped projections must follow the same conservative attribution rules as the metrics-stack and dashboard contracts.",
      "Stale probe evidence cannot be projected as current healthy or ready status."
    ]
  },
  "exposure_templates": {
    "aggregate": {
      "health": {
        "path": "/internal/health",
        "audience": "platform_operations",
        "internal_only": true,
        "scope": "platform"
      },
      "readiness": {
        "path": "/internal/ready",
        "audience": "orchestration_and_platform_operations",
        "internal_only": true,
        "scope": "platform"
      },
      "liveness": {
        "path": "/internal/live",
        "audience": "orchestration_and_platform_operations",
        "internal_only": true,
        "scope": "platform"
      }
    },
    "component": {
      "health": {
        "path": "/internal/health/components/{componentId}",
        "audience": "platform_operations",
        "internal_only": true,
        "scope": "platform_or_inherited_narrower_view"
      },
      "readiness": {
        "path": "/internal/ready/components/{componentId}",
        "audience": "orchestration_and_platform_operations",
        "internal_only": true,
        "scope": "platform_or_inherited_narrower_view"
      },
      "liveness": {
        "path": "/internal/live/components/{componentId}",
        "audience": "orchestration_and_platform_operations",
        "internal_only": true,
        "scope": "platform_or_inherited_narrower_view"
      }
    }
  },
  "dashboard_alignment": {
    "compatible_health_states": [
      "healthy",
      "degraded",
      "unavailable",
      "unknown",
      "stale",
      "inherited"
    ],
    "rules": [
      "Dashboards may summarize probe outcomes, but they must not redefine probe semantics.",
      "Tenant and workspace views may expose inherited platform dependency posture only in redacted, non-comparative form.",
      "Workspace-safe detail must be explicit; otherwise the result falls back to inherited or masked posture."
    ]
  },
