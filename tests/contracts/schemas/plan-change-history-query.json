{
  "openapi": "3.1.0",
  "info": {
    "title": "Plan Change History Query API",
    "version": "2026-03-31"
  },
  "paths": {
    "/v1/tenants/{tenantId}/plan/history-impact": {
      "get": {
        "summary": "Query immutable plan change history with impact snapshots",
        "parameters": [
          { "name": "tenantId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "page", "in": "query", "schema": { "type": "integer", "minimum": 1, "default": 1 } },
          { "name": "pageSize", "in": "query", "schema": { "type": "integer", "minimum": 1, "maximum": 100, "default": 20 } },
          { "name": "actorId", "in": "query", "schema": { "type": "string" } },
          { "name": "from", "in": "query", "schema": { "type": "string", "format": "date-time" } },
          { "name": "to", "in": "query", "schema": { "type": "string", "format": "date-time" } }
        ],
        "responses": {
          "200": {
            "description": "Paginated plan change history",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["items", "total", "page", "pageSize"],
                  "properties": {
                    "items": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "required": ["historyEntryId", "tenantId", "newPlanId", "actorId", "effectiveAt", "quotaImpacts", "capabilityImpacts"],
                        "properties": {
                          "historyEntryId": { "type": "string", "format": "uuid" },
                          "tenantId": { "type": "string" },
                          "previousPlanId": { "type": ["string", "null"], "format": "uuid" },
                          "newPlanId": { "type": "string", "format": "uuid" },
                          "actorId": { "type": "string" },
                          "effectiveAt": { "type": "string", "format": "date-time" },
                          "correlationId": { "type": ["string", "null"] },
                          "changeReason": { "type": ["string", "null"] },
                          "changeDirection": { "type": "string", "enum": ["upgrade", "downgrade", "lateral", "equivalent", "initial_assignment"] },
                          "usageCollectionStatus": { "type": "string", "enum": ["complete", "partial", "unavailable"] },
                          "overLimitDimensionCount": { "type": "integer", "minimum": 0 },
                          "quotaImpacts": {
                            "type": "array",
                            "items": {
                              "type": "object",
                              "required": ["dimensionKey", "comparison", "newEffectiveValueKind", "usageStatus"],
                              "properties": {
                                "dimensionKey": { "type": "string" },
                                "displayLabel": { "type": "string" },
                                "unit": { "type": "string" },
                                "previousEffectiveValueKind": { "type": "string", "enum": ["bounded", "unlimited", "missing"] },
                                "previousEffectiveValue": { "type": ["integer", "null"] },
                                "newEffectiveValueKind": { "type": "string", "enum": ["bounded", "unlimited", "missing"] },
                                "newEffectiveValue": { "type": ["integer", "null"] },
                                "comparison": { "type": "string", "enum": ["increased", "decreased", "unchanged", "added", "removed"] },
                                "observedUsage": { "type": ["integer", "null"] },
                                "usageStatus": { "type": "string", "enum": ["within_limit", "at_limit", "over_limit", "unknown"] },
                                "usageUnknownReason": { "type": ["string", "null"] }
                              }
                            }
                          },
                          "capabilityImpacts": {
                            "type": "array",
                            "items": {
                              "type": "object",
                              "required": ["capabilityKey", "comparison"],
                              "properties": {
                                "capabilityKey": { "type": "string" },
                                "displayLabel": { "type": "string" },
                                "previousState": { "type": ["boolean", "null"] },
                                "newState": { "type": ["boolean", "null"] },
                                "comparison": { "type": "string", "enum": ["enabled", "disabled", "unchanged"] }
                              }
                            }
                          }
                        }
                      }
                    },
                    "total": { "type": "integer", "minimum": 0 },
                    "page": { "type": "integer", "minimum": 1 },
                    "pageSize": { "type": "integer", "minimum": 1 }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
