{
  "openapi": "3.1.0",
  "info": {
    "title": "Plan Effective Entitlements API",
    "version": "2026-03-31"
  },
  "paths": {
    "/v1/tenant/plan/effective-entitlements": {
      "get": {
        "summary": "Get current effective entitlements for the authenticated tenant",
        "responses": {
          "200": {
            "description": "Current effective entitlement summary",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["tenantId", "planId", "planSlug", "effectiveFrom", "quotaDimensions", "capabilities"],
                  "properties": {
                    "tenantId": { "type": "string" },
                    "planId": { "type": "string", "format": "uuid" },
                    "planSlug": { "type": "string" },
                    "planDisplayName": { "type": "string" },
                    "effectiveFrom": { "type": "string", "format": "date-time" },
                    "latestHistoryEntryId": { "type": ["string", "null"], "format": "uuid" },
                    "latestPlanChangeAt": { "type": ["string", "null"], "format": "date-time" },
                    "quotaDimensions": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "required": ["dimensionKey", "effectiveValueKind", "usageStatus"],
                        "properties": {
                          "dimensionKey": { "type": "string" },
                          "displayLabel": { "type": "string" },
                          "unit": { "type": "string" },
                          "effectiveValueKind": { "type": "string", "enum": ["bounded", "unlimited", "missing"] },
                          "effectiveValue": { "type": ["integer", "null"] },
                          "observedUsage": { "type": ["integer", "null"] },
                          "usageStatus": { "type": "string", "enum": ["within_limit", "at_limit", "over_limit", "unknown"] },
                          "usageUnknownReason": { "type": ["string", "null"] }
                        }
                      }
                    },
                    "capabilities": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "required": ["capabilityKey", "enabled"],
                        "properties": {
                          "capabilityKey": { "type": "string" },
                          "displayLabel": { "type": "string" },
                          "enabled": { "type": "boolean" }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
