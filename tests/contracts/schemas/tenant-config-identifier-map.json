{
  "openapi": "3.0.3",
  "info": {
    "title": "Tenant Config Identifier Map",
    "version": "1.0.0",
    "description": "Generate a proposed identifier map for applying an export artifact to a destination tenant."
  },
  "paths": {
    "/v1/admin/tenants/{tenant_id}/config/reprovision/identifier-map": {
      "post": {
        "operationId": "generateTenantConfigIdentifierMap",
        "summary": "Generate a proposed identifier map",
        "description": "Inspects the export artifact and returns a tenant-specific identifier map proposal without changing any external system.",
        "tags": ["config-reprovision"],
        "security": [{ "openIdConnect": ["platform:admin:config:reprovision"] }],
        "parameters": [
          {
            "name": "tenant_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Destination tenant identifier"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/IdentifierMapRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Identifier map proposal generated successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/IdentifierMapResponse" }
              }
            }
          },
          "400": {
            "description": "Malformed request or invalid artifact payload",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "403": {
            "description": "Insufficient privilege",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "404": {
            "description": "Destination tenant not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "422": {
            "description": "Artifact cannot be used to derive a valid identifier map",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "IdentifierMapRequest": {
        "type": "object",
        "required": ["artifact"],
        "properties": {
          "artifact": { "$ref": "#/components/schemas/ExportArtifact" }
        }
      },
      "ExportArtifact": {
        "type": "object",
        "required": ["export_timestamp", "tenant_id", "format_version", "deployment_profile", "correlation_id", "domains"],
        "properties": {
          "export_timestamp": { "type": "string", "format": "date-time" },
          "tenant_id": { "type": "string" },
          "format_version": { "type": "string", "example": "1.0.0" },
          "deployment_profile": { "type": "string" },
          "correlation_id": { "type": "string" },
          "domains": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/DomainArtifact" }
          }
        }
      },
      "DomainArtifact": {
        "type": "object",
        "required": ["domain_key", "status", "exported_at"],
        "properties": {
          "domain_key": { "type": "string", "enum": ["iam", "postgres_metadata", "mongo_metadata", "kafka", "functions", "storage"] },
          "status": { "type": "string", "enum": ["ok", "empty", "error", "not_available", "not_requested"] },
          "exported_at": { "type": "string", "format": "date-time" },
          "items_count": { "type": ["integer", "null"], "minimum": 0 },
          "data": { "type": ["object", "null"] },
          "error": { "type": ["string", "null"] },
          "reason": { "type": ["string", "null"] }
        }
      },
      "IdentifierMapResponse": {
        "type": "object",
        "required": ["source_tenant_id", "target_tenant_id", "proposal", "correlation_id"],
        "properties": {
          "source_tenant_id": { "type": "string" },
          "target_tenant_id": { "type": "string" },
          "proposal": { "$ref": "#/components/schemas/IdentifierMap" },
          "warnings": { "type": "array", "items": { "type": "string" } },
          "correlation_id": { "type": "string" }
        }
      },
      "IdentifierMap": {
        "type": "object",
        "required": ["entries"],
        "properties": {
          "source_tenant_id": { "type": ["string", "null"] },
          "target_tenant_id": { "type": ["string", "null"] },
          "entries": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/IdentifierMapEntry" }
          },
          "overrides": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          }
        }
      },
      "IdentifierMapEntry": {
        "type": "object",
        "required": ["from", "to"],
        "properties": {
          "from": { "type": "string", "minLength": 1 },
          "to": { "type": "string", "minLength": 1 },
          "scope": { "type": ["string", "null"] },
          "description": { "type": ["string", "null"] }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": ["error", "message"],
        "properties": {
          "error": { "type": "string" },
          "message": { "type": "string" },
          "correlation_id": { "type": "string" }
        }
      }
    },
    "securitySchemes": {
      "openIdConnect": {
        "type": "openIdConnect",
        "openIdConnectUrl": "/.well-known/openid-configuration"
      }
    }
  }
}