{
  "openapi": "3.0.3",
  "info": {
    "title": "Tenant Config Reprovision",
    "version": "1.0.0",
    "description": "Apply a validated tenant configuration export artifact to a destination tenant, with optional identifier-map overrides, domain filtering, and dry-run support."
  },
  "paths": {
    "/v1/admin/tenants/{tenant_id}/config/reprovision": {
      "post": {
        "operationId": "reprovisionTenantConfig",
        "summary": "Reprovision a tenant from an export artifact",
        "description": "Applies configuration from an export artifact to the destination tenant. The request may include an identifier map override, a subset of domains to apply, and a dry_run flag. The operation is best-effort per domain and never overwrites conflicting resources automatically.",
        "tags": ["config-reprovision"],
        "security": [{ "openIdConnect": ["platform:admin:config:reprovision"] }],
        "parameters": [
          {
            "name": "tenant_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Destination tenant identifier"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ReprovisionRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful reprovision or successful dry-run",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ReprovisionResult" }
              }
            }
          },
          "207": {
            "description": "Partial reprovision: at least one domain failed or had conflicts, but the operation completed for the rest",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ReprovisionResult" }
              }
            }
          },
          "400": {
            "description": "Malformed request or invalid identifier map",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "403": {
            "description": "Insufficient privilege",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "404": {
            "description": "Destination tenant not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "409": {
            "description": "A reprovision is already in progress for this tenant",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "413": {
            "description": "Artifact or request body exceeds the configured size limit",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "422": {
            "description": "Artifact is not valid for reprovisioning: incompatible format_version, validation failure, or incompatible major version",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ReprovisionRequest": {
        "type": "object",
        "required": ["artifact"],
        "properties": {
          "artifact": { "$ref": "#/components/schemas/ExportArtifact" },
          "identifier_map": { "$ref": "#/components/schemas/IdentifierMap" },
          "domains": {
            "type": "array",
            "items": { "type": "string", "enum": ["iam", "postgres_metadata", "mongo_metadata", "kafka", "functions", "storage"] },
            "description": "Optional list of domain keys to apply"
          },
          "dry_run": {
            "type": "boolean",
            "default": false,
            "description": "When true, evaluate the reprovision plan without modifying external systems"
          }
        }
      },
      "ExportArtifact": {
        "type": "object",
        "required": ["export_timestamp", "tenant_id", "format_version", "deployment_profile", "correlation_id", "domains"],
        "properties": {
          "export_timestamp": { "type": "string", "format": "date-time" },
          "tenant_id": { "type": "string" },
          "format_version": { "type": "string", "example": "1.0.0" },
          "deployment_profile": { "type": "string" },
          "correlation_id": { "type": "string" },
          "domains": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/DomainArtifact" }
          }
        }
      },
      "DomainArtifact": {
        "type": "object",
        "required": ["domain_key", "status", "exported_at"],
        "properties": {
          "domain_key": { "type": "string", "enum": ["iam", "postgres_metadata", "mongo_metadata", "kafka", "functions", "storage"] },
          "status": { "type": "string", "enum": ["ok", "empty", "error", "not_available", "not_requested"] },
          "exported_at": { "type": "string", "format": "date-time" },
          "items_count": { "type": ["integer", "null"], "minimum": 0 },
          "data": { "type": ["object", "null"] },
          "error": { "type": ["string", "null"] },
          "reason": { "type": ["string", "null"] }
        }
      },
      "IdentifierMap": {
        "type": "object",
        "required": ["entries"],
        "properties": {
          "source_tenant_id": { "type": ["string", "null"] },
          "target_tenant_id": { "type": ["string", "null"] },
          "entries": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "#/components/schemas/IdentifierMapEntry" }
          },
          "overrides": {
            "type": "object",
            "additionalProperties": { "type": "string" },
            "description": "Optional manual overrides keyed by identifier scope"
          }
        }
      },
      "IdentifierMapEntry": {
        "type": "object",
        "required": ["from", "to"],
        "properties": {
          "from": { "type": "string", "minLength": 1 },
          "to": { "type": "string", "minLength": 1 },
          "scope": { "type": ["string", "null"] },
          "description": { "type": ["string", "null"] }
        }
      },
      "ReprovisionResult": {
        "type": "object",
        "required": ["tenant_id", "source_tenant_id", "dry_run", "status", "domain_results", "summary", "correlation_id"],
        "properties": {
          "tenant_id": { "type": "string" },
          "source_tenant_id": { "type": "string" },
          "dry_run": { "type": "boolean" },
          "status": { "type": "string", "enum": ["success", "partial", "failed", "blocked", "dry_run"] },
          "identifier_map": { "$ref": "#/components/schemas/IdentifierMap" },
          "lock": {
            "type": "object",
            "nullable": true,
            "properties": {
              "acquired": { "type": "boolean" },
              "expires_at": { "type": ["string", "null"], "format": "date-time" },
              "lock_token": { "type": ["string", "null"] }
            }
          },
          "domain_results": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/DomainResult" }
          },
          "summary": { "$ref": "#/components/schemas/ReprovisionSummary" },
          "warnings": {
            "type": "array",
            "items": { "type": "string" }
          },
          "correlation_id": { "type": "string" }
        }
      },
      "DomainResult": {
        "type": "object",
        "required": ["domain_key", "status", "resource_results"],
        "properties": {
          "domain_key": { "type": "string", "enum": ["iam", "postgres_metadata", "mongo_metadata", "kafka", "functions", "storage"] },
          "status": {
            "type": "string",
            "enum": ["applied", "applied_with_warnings", "skipped", "skipped_not_exportable", "skipped_no_applier", "conflict", "error", "would_apply", "would_conflict", "would_skip"]
          },
          "resource_results": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ResourceResult" }
          },
          "counts": {
            "type": "object",
            "properties": {
              "created": { "type": "integer" },
              "skipped": { "type": "integer" },
              "conflicts": { "type": "integer" },
              "errors": { "type": "integer" },
              "warnings": { "type": "integer" }
            }
          },
          "message": { "type": ["string", "null"] }
        }
      },
      "ResourceResult": {
        "type": "object",
        "required": ["resource_type", "resource_name", "action"],
        "properties": {
          "resource_type": { "type": "string" },
          "resource_name": { "type": "string" },
          "resource_id": { "type": ["string", "null"] },
          "action": { "type": "string", "enum": ["created", "skipped", "conflict", "error", "applied_with_warnings", "would_create", "would_skip", "would_conflict"] },
          "message": { "type": ["string", "null"] },
          "warnings": { "type": "array", "items": { "type": "string" } },
          "diff": { "type": ["object", "null"] }
        }
      },
      "ReprovisionSummary": {
        "type": "object",
        "required": ["domains_requested", "domains_processed", "domains_skipped", "resources_created", "resources_skipped", "resources_conflicted", "resources_failed"],
        "properties": {
          "domains_requested": { "type": "integer" },
          "domains_processed": { "type": "integer" },
          "domains_skipped": { "type": "integer" },
          "resources_created": { "type": "integer" },
          "resources_skipped": { "type": "integer" },
          "resources_conflicted": { "type": "integer" },
          "resources_failed": { "type": "integer" }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": ["error", "message"],
        "properties": {
          "error": { "type": "string" },
          "message": { "type": "string" },
          "correlation_id": { "type": "string" }
        }
      }
    },
    "securitySchemes": {
      "openIdConnect": {
        "type": "openIdConnect",
        "openIdConnectUrl": "/.well-known/openid-configuration"
      }
    }
  }
}