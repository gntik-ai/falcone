{
  "openapi": "3.1.0",
  "info": {
    "title": "Plan Assignment Policy Evaluation Response",
    "version": "1.0.0",
    "description": "Schema for the plan-assign action response once transition policies are enforced."
  },
  "paths": {
    "/v1/admin/tenants/{tenantId}/plan-assign": {
      "post": {
        "summary": "Assign a target plan to a tenant and return the transition policy evaluation summary",
        "parameters": [
          {
            "name": "tenantId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PlanAssignRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Assignment completed or no-op",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PlanAssignResponse"
                }
              }
            }
          },
          "409": { "description": "Transition already in progress" },
          "422": { "description": "Blocked by rule, approval requirement, or excess policy" }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "PlanAssignRequest": {
        "type": "object",
        "required": ["targetPlanId"],
        "properties": {
          "targetPlanId": { "type": "string", "format": "uuid" },
          "acknowledgmentFlag": {
            "type": "boolean",
            "description": "Required when the matched compatibility rule is allowed_with_approval."
          },
          "correlationId": { "type": "string" }
        },
        "additionalProperties": false
      },
      "TransitionDirection": {
        "type": "string",
        "enum": ["upgrade", "downgrade", "lateral", "initial_assignment", "equivalent"]
      },
      "FinalOutcome": {
        "type": "string",
        "enum": ["allowed", "allowed_with_approval", "blocked_by_rule", "blocked_by_excess", "no_op"]
      },
      "PolicyMode": {
        "type": "string",
        "enum": ["grace_period", "block_creation", "block_transition"]
      },
      "PolicyLayer": {
        "type": "string",
        "enum": ["dimension_override", "transition_override", "platform_default", "built_in_fallback"]
      },
      "OverLimitDimension": {
        "type": "object",
        "required": [
          "dimensionKey",
          "effectiveLimit",
          "observedConsumption",
          "policyApplied",
          "policyLayer"
        ],
        "properties": {
          "dimensionKey": { "type": "string", "maxLength": 64 },
          "effectiveLimit": { "type": "integer" },
          "observedConsumption": { "type": "integer" },
          "policyApplied": { "$ref": "#/components/schemas/PolicyMode" },
          "policyLayer": { "$ref": "#/components/schemas/PolicyLayer" },
          "gracePeriodDays": { "type": ["integer", "null"], "minimum": 1 },
          "expiresAt": { "type": ["string", "null"], "format": "date-time" },
          "evaluationStatus": {
            "type": ["string", "null"],
            "enum": ["active", "deferred", "resolved", null]
          }
        },
        "additionalProperties": false
      },
      "PolicyEvaluationSummary": {
        "type": "object",
        "required": ["transitionDirection", "finalOutcome", "overLimitDimensions"],
        "properties": {
          "transitionDirection": { "$ref": "#/components/schemas/TransitionDirection" },
          "matchedRuleId": { "type": ["string", "null"], "format": "uuid" },
          "ruleDisposition": {
            "type": ["string", "null"],
            "enum": ["allowed", "allowed_with_approval", "blocked", null]
          },
          "finalOutcome": { "$ref": "#/components/schemas/FinalOutcome" },
          "overLimitDimensions": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/OverLimitDimension" }
          }
        },
        "additionalProperties": false
      },
      "PlanAssignResponse": {
        "type": "object",
        "required": ["tenantId", "sourcePlanId", "targetPlanId", "policyEvaluationSummary", "finalOutcome"],
        "properties": {
          "tenantId": { "type": "string" },
          "sourcePlanId": { "type": ["string", "null"], "format": "uuid" },
          "targetPlanId": { "type": "string", "format": "uuid" },
          "finalOutcome": { "$ref": "#/components/schemas/FinalOutcome" },
          "policyEvaluationSummary": { "$ref": "#/components/schemas/PolicyEvaluationSummary" },
          "overLimitDimensions": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/OverLimitDimension" }
          },
          "auditEventId": { "type": ["string", "null"], "format": "uuid" }
        },
        "additionalProperties": false
      }
    }
  }
}
