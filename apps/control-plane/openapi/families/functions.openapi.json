{
  "components": {
    "parameters": {
      "IdempotencyKey": {
        "description": "Stable idempotency token for safe retries of POST, PUT, PATCH, and DELETE operations routed through the gateway. Replays are retained for 24h and surfaced through X-Idempotency-Replayed.",
        "in": "header",
        "name": "Idempotency-Key",
        "required": true,
        "schema": {
          "maxLength": 128,
          "minLength": 8,
          "pattern": "^[A-Za-z0-9._:-]{8,128}$",
          "type": "string"
        }
      },
      "ResourceId": {
        "description": "Stable managed resource identifier.",
        "in": "path",
        "name": "resourceId",
        "required": true,
        "schema": {
          "pattern": "^res_[0-9a-z]+$",
          "type": "string"
        }
      },
      "XApiVersion": {
        "description": "Pinned additive contract version for the v1 public API release published with gateway QoS and hardening support.",
        "in": "header",
        "name": "X-API-Version",
        "required": true,
        "schema": {
          "const": "2026-03-25",
          "pattern": "^2026-03-24$",
          "type": "string"
        }
      },
      "XCorrelationId": {
        "description": "Stable request correlation identifier reused by downstream authorization, orchestration, audit flows, and backfilled by the gateway when recovery requires it.",
        "in": "header",
        "name": "X-Correlation-Id",
        "required": true,
        "schema": {
          "maxLength": 128,
          "minLength": 8,
          "pattern": "^[A-Za-z0-9._:-]{8,128}$",
          "type": "string"
        }
      }
    },
    "schemas": {
      "ErrorDetail": {
        "additionalProperties": true,
        "properties": {
          "reason": {
            "type": "string"
          },
          "violations": {
            "items": {
              "type": "string"
            },
            "type": "array"
          }
        },
        "type": "object"
      },
      "ErrorResource": {
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "type": {
            "type": "string"
          }
        },
        "required": [
          "path"
        ],
        "type": "object"
      },
      "ErrorResponse": {
        "additionalProperties": false,
        "properties": {
          "code": {
            "pattern": "^GW_[A-Z0-9_]+$",
            "type": "string"
          },
          "correlationId": {
            "maxLength": 128,
            "minLength": 8,
            "pattern": "^[A-Za-z0-9._:-]{8,128}$",
            "type": "string"
          },
          "detail": {
            "$ref": "#/components/schemas/ErrorDetail"
          },
          "message": {
            "type": "string"
          },
          "requestId": {
            "maxLength": 128,
            "minLength": 8,
            "type": "string"
          },
          "resource": {
            "$ref": "#/components/schemas/ErrorResource"
          },
          "retryable": {
            "type": "boolean"
          },
          "status": {
            "maximum": 599,
            "minimum": 400,
            "type": "integer"
          },
          "timestamp": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "status",
          "code",
          "message",
          "detail",
          "requestId",
          "correlationId",
          "timestamp",
          "resource"
        ],
        "type": "object"
      },
      "FunctionAction": {
        "additionalProperties": false,
        "properties": {
          "entrypoint": {
            "maxLength": 120,
            "minLength": 3,
            "type": "string"
          },
          "provisioning": {
            "$ref": "#/components/schemas/ProvisioningResourceState"
          },
          "resourceId": {
            "pattern": "^res_[0-9a-z]+$",
            "type": "string"
          },
          "runtime": {
            "maxLength": 40,
            "minLength": 3,
            "type": "string"
          },
          "status": {
            "enum": [
              "draft",
              "deploying",
              "active",
              "suspended"
            ],
            "type": "string"
          },
          "tenantId": {
            "pattern": "^ten_[0-9a-z]+$",
            "type": "string"
          },
          "timestamps": {
            "$ref": "#/components/schemas/LifecycleTimestamps"
          },
          "workspaceId": {
            "pattern": "^wrk_[0-9a-z]+$",
            "type": "string"
          }
        },
        "required": [
          "resourceId",
          "tenantId",
          "workspaceId",
          "runtime",
          "entrypoint",
          "status",
          "timestamps"
        ],
        "type": "object"
      },
      "FunctionActionWriteRequest": {
        "additionalProperties": false,
        "properties": {
          "deploymentDigest": {
            "maxLength": 255,
            "minLength": 12,
            "type": "string"
          },
          "entrypoint": {
            "maxLength": 120,
            "minLength": 3,
            "type": "string"
          },
          "runtime": {
            "maxLength": 40,
            "minLength": 3,
            "type": "string"
          },
          "tenantId": {
            "pattern": "^ten_[0-9a-z]+$",
            "type": "string"
          },
          "workspaceId": {
            "pattern": "^wrk_[0-9a-z]+$",
            "type": "string"
          }
        },
        "required": [
          "tenantId",
          "workspaceId",
          "runtime",
          "entrypoint"
        ],
        "type": "object"
      },
      "GatewayMutationAccepted": {
        "additionalProperties": false,
        "properties": {
          "acceptedAt": {
            "format": "date-time",
            "type": "string"
          },
          "correlationId": {
            "maxLength": 128,
            "minLength": 8,
            "type": "string"
          },
          "family": {
            "type": "string"
          },
          "requestId": {
            "maxLength": 128,
            "minLength": 8,
            "type": "string"
          },
          "resourceId": {
            "type": "string"
          },
          "resourceType": {
            "type": "string"
          },
          "status": {
            "enum": [
              "accepted",
              "queued"
            ],
            "type": "string"
          }
        },
        "required": [
          "requestId",
          "status",
          "family",
          "resourceType",
          "resourceId",
          "correlationId",
          "acceptedAt"
        ],
        "type": "object"
      },
      "LifecycleTimestamps": {
        "additionalProperties": false,
        "properties": {
          "activatedAt": {
            "format": "date-time",
            "type": "string"
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          },
          "deletedAt": {
            "format": "date-time",
            "type": "string"
          },
          "suspendedAt": {
            "format": "date-time",
            "type": "string"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "createdAt",
          "updatedAt"
        ],
        "type": "object"
      },
      "ProvisioningFailureClass": {
        "enum": [
          "retryable_dependency_failure",
          "terminal_dependency_failure",
          "validation_error",
          "authorization_error"
        ],
        "type": "string"
      },
      "ProvisioningGatingMode": {
        "enum": [
          "always",
          "capability_gated"
        ],
        "type": "string"
      },
      "ProvisioningResourceState": {
        "additionalProperties": false,
        "properties": {
          "attemptCount": {
            "minimum": 0,
            "type": "integer"
          },
          "displayName": {
            "maxLength": 120,
            "minLength": 3,
            "type": "string"
          },
          "failureClass": {
            "$ref": "#/components/schemas/ProvisioningFailureClass"
          },
          "gatingMode": {
            "$ref": "#/components/schemas/ProvisioningGatingMode"
          },
          "lastAttemptAt": {
            "format": "date-time",
            "type": "string"
          },
          "provider": {
            "maxLength": 120,
            "minLength": 2,
            "type": "string"
          },
          "providerReference": {
            "maxLength": 255,
            "minLength": 3,
            "type": "string"
          },
          "requiredCapabilityKey": {
            "maxLength": 120,
            "minLength": 3,
            "type": "string"
          },
          "resourceKey": {
            "pattern": "^[a-z0-9](?:[a-z0-9_-]{1,62}[a-z0-9])?$",
            "type": "string"
          },
          "resourceType": {
            "enum": [
              "tenant",
              "tenant_membership",
              "workspace",
              "workspace_membership",
              "identity_context",
              "postgres_instance",
              "storage_bucket",
              "mongo_database",
              "event_topic",
              "function_action"
            ],
            "type": "string"
          },
          "scope": {
            "enum": [
              "tenant",
              "workspace"
            ],
            "type": "string"
          },
          "status": {
            "$ref": "#/components/schemas/ProvisioningResourceStatus"
          },
          "visibleInConsole": {
            "type": "boolean"
          }
        },
        "required": [
          "resourceKey",
          "resourceType",
          "scope",
          "gatingMode",
          "status",
          "attemptCount",
          "visibleInConsole"
        ],
        "type": "object"
      },
      "ProvisioningResourceStatus": {
        "enum": [
          "pending",
          "in_progress",
          "provisioned",
          "skipped",
          "failed",
          "retry_scheduled"
        ],
        "type": "string"
      }
    }
  },
  "info": {
    "description": "Workspace-scoped serverless function management and invocation contracts routed by the gateway. Generated from the unified public API contract for v1.",
    "summary": "Workspace-scoped serverless function management and invocation contracts routed by the gateway.",
    "title": "In Atelier Functions API",
    "version": "1.18.0"
  },
  "jsonSchemaDialect": "https://json-schema.org/draft/2020-12/schema",
  "openapi": "3.1.0",
  "paths": {
    "/v1/functions/actions": {
      "post": {
        "operationId": "createFunctions",
        "parameters": [
          {
            "$ref": "#/components/parameters/XApiVersion"
          },
          {
            "$ref": "#/components/parameters/XCorrelationId"
          },
          {
            "$ref": "#/components/parameters/IdempotencyKey"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FunctionActionWriteRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "202": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GatewayMutationAccepted"
                }
              }
            },
            "description": "Function action deployment request accepted."
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "The request is malformed or contextually inconsistent."
          },
          "403": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "The caller is authenticated but not authorized for this scope."
          },
          "413": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Gateway rejected the request because the body exceeded the configured size budget for this route family."
          },
          "429": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Gateway QoS policy rejected the request rate for this route family."
          },
          "431": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Gateway rejected one or more invalid or oversized request headers."
          },
          "504": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Gateway timed out while waiting for the downstream control-plane or adapter response."
          },
          "default": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Unexpected gateway error."
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Submit a workspace-scoped function action provisioning request through the unified functions family",
        "tags": [
          "Functions"
        ],
        "x-audiences": [
          "developer_external",
          "workspace_owner",
          "workspace_admin",
          "workspace_developer",
          "platform_team"
        ],
        "x-downstream-adapters": [
          "openwhisk"
        ],
        "x-family": "functions",
        "x-owning-service": "control_api",
        "x-rate-limit-class": "data-control",
        "x-resource-type": "function",
        "x-scope": "workspace",
        "x-visibility": "public"
      }
    },
    "/v1/functions/actions/{resourceId}": {
      "get": {
        "operationId": "getFunctions",
        "parameters": [
          {
            "$ref": "#/components/parameters/XApiVersion"
          },
          {
            "$ref": "#/components/parameters/XCorrelationId"
          },
          {
            "$ref": "#/components/parameters/ResourceId"
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FunctionAction"
                }
              }
            },
            "description": "Resource returned."
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "The request is malformed or contextually inconsistent."
          },
          "403": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "The caller is authenticated but not authorized for this scope."
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "The requested resource was not found."
          },
          "429": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Gateway QoS policy rejected the request rate for this route family."
          },
          "431": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Gateway rejected one or more invalid or oversized request headers."
          },
          "504": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Gateway timed out while waiting for the downstream control-plane or adapter response."
          },
          "default": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Unexpected gateway error."
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Fetch one workspace-scoped function action contract under the functions family",
        "tags": [
          "Functions"
        ],
        "x-audiences": [
          "developer_external",
          "workspace_owner",
          "workspace_admin",
          "workspace_developer",
          "workspace_viewer",
          "workspace_service_account",
          "platform_team"
        ],
        "x-downstream-adapters": [
          "openwhisk"
        ],
        "x-family": "functions",
        "x-owning-service": "control_api",
        "x-rate-limit-class": "data-read",
        "x-resource-type": "function",
        "x-scope": "workspace",
        "x-visibility": "public"
      }
    }
  },
  "servers": [
    {
      "url": "https://{publicHost}",
      "variables": {
        "publicHost": {
          "default": "api.dev.in-atelier.example.com",
          "enum": [
            "api.dev.in-atelier.example.com",
            "api.sandbox.in-atelier.example.com",
            "api.staging.in-atelier.example.com",
            "api.in-atelier.example.com"
          ]
        }
      }
    }
  ],
  "tags": [
    {
      "name": "Functions"
    }
  ]
}
