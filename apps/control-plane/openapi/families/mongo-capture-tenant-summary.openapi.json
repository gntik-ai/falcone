{
  "components": {
    "parameters": {
      "TenantId": {
        "description": "Stable tenant identifier.",
        "in": "path",
        "name": "tenantId",
        "required": true,
        "schema": {
          "minLength": 3,
          "pattern": "^ten_[0-9a-z]+$",
          "type": "string"
        }
      },
      "XApiVersion": {
        "description": "Pinned additive contract version for the v1 public API release published with gateway QoS and hardening support.",
        "in": "header",
        "name": "X-API-Version",
        "required": true,
        "schema": {
          "const": "2026-03-26",
          "pattern": "^2026-03-26$",
          "type": "string"
        }
      },
      "XCorrelationId": {
        "description": "Stable request correlation identifier reused by downstream authorization, orchestration, audit flows, and backfilled by the gateway when recovery requires it.",
        "in": "header",
        "name": "X-Correlation-Id",
        "required": true,
        "schema": {
          "maxLength": 128,
          "minLength": 8,
          "pattern": "^[A-Za-z0-9._:-]{8,128}$",
          "type": "string"
        }
      }
    },
    "schemas": {
      "ErrorDetail": {
        "additionalProperties": true,
        "properties": {
          "reason": {
            "type": "string"
          },
          "violations": {
            "items": {
              "type": "string"
            },
            "type": "array"
          }
        },
        "type": "object"
      },
      "ErrorResource": {
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "type": {
            "type": "string"
          }
        },
        "required": [
          "path"
        ],
        "type": "object"
      },
      "ErrorResponse": {
        "additionalProperties": false,
        "properties": {
          "code": {
            "pattern": "^GW_[A-Z0-9_]+$",
            "type": "string"
          },
          "correlationId": {
            "maxLength": 128,
            "minLength": 8,
            "pattern": "^[A-Za-z0-9._:-]{8,128}$",
            "type": "string"
          },
          "detail": {
            "$ref": "#/components/schemas/ErrorDetail"
          },
          "message": {
            "type": "string"
          },
          "requestId": {
            "maxLength": 128,
            "minLength": 8,
            "type": "string"
          },
          "resource": {
            "$ref": "#/components/schemas/ErrorResource"
          },
          "retryable": {
            "type": "boolean"
          },
          "status": {
            "maximum": 599,
            "minimum": 400,
            "type": "integer"
          },
          "timestamp": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "status",
          "code",
          "message",
          "detail",
          "requestId",
          "correlationId",
          "timestamp",
          "resource"
        ],
        "type": "object"
      }
    }
  },
  "info": {
    "description": "Tenant-scoped MongoDB change-capture summary surfaces. Generated from the unified public API contract for v1.",
    "summary": "Tenant-scoped MongoDB change-capture summary surfaces.",
    "title": "In Atelier Mongo Capture Tenant Summary API",
    "version": "1.21.0"
  },
  "jsonSchemaDialect": "https://json-schema.org/draft/2020-12/schema",
  "openapi": "3.1.0",
  "paths": {
    "/v1/realtime/tenants/{tenantId}/mongo-captures/summary": {
      "get": {
        "operationId": "getTenantMongoCaptureSummary",
        "parameters": [
          {
            "$ref": "#/components/parameters/XApiVersion"
          },
          {
            "$ref": "#/components/parameters/XCorrelationId"
          },
          {
            "$ref": "#/components/parameters/TenantId"
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            },
            "description": "Tenant capture summary."
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Unauthorized."
          },
          "403": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Forbidden."
          },
          "429": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Gateway QoS policy rejected the request rate for this route family."
          },
          "431": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Gateway rejected one or more invalid or oversized request headers."
          },
          "504": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Gateway timed out while waiting for the downstream control-plane or adapter response."
          },
          "default": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Unexpected control-plane error."
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "List active MongoDB change stream captures across tenant workspaces",
        "tags": [
          "Tenants",
          "Realtime",
          "MongoCaptures"
        ],
        "x-audiences": [
          "developer_external",
          "tenant_owner",
          "tenant_admin",
          "platform_team"
        ],
        "x-family": "mongo-capture-tenant-summary",
        "x-owning-service": "control_api",
        "x-rate-limit-class": "control-read",
        "x-resource-type": "mongo_capture_summary",
        "x-scope": "tenant",
        "x-visibility": "public"
      }
    }
  },
  "servers": [
    {
      "url": "https://{publicHost}",
      "variables": {
        "publicHost": {
          "default": "api.dev.in-atelier.example.com",
          "enum": [
            "api.dev.in-atelier.example.com",
            "api.sandbox.in-atelier.example.com",
            "api.staging.in-atelier.example.com",
            "api.in-atelier.example.com"
          ]
        }
      }
    }
  ],
  "tags": [
    {
      "name": "Tenants"
    }
  ]
}
