        ],
        "x-audiences": [
          "developer_external",
          "workspace_owner",
          "workspace_admin",
          "workspace_operator",
          "workspace_viewer",
          "workspace_service_account",
          "platform_team"
        ],
        "x-downstream-adapters": [
          "kafka"
        ],
        "x-family": "events",
        "x-owning-service": "event_gateway",
        "x-rate-limit-class": "data-read",
        "x-resource-type": "topic",
        "x-scope": "workspace",
        "x-visibility": "public"
      }
    },
    "/v1/events/topics/{resourceId}/publish": {
      "post": {
        "operationId": "publishEventToTopic",
        "parameters": [
          {
            "$ref": "#/components/parameters/XApiVersion"
          },
          {
            "$ref": "#/components/parameters/XCorrelationId"
          },
          {
            "$ref": "#/components/parameters/IdempotencyKey"
          },
          {
            "$ref": "#/components/parameters/ResourceId"
          }
        ],
        "requestBody": {
          "content": {
            "application/cloudevents+json": {
