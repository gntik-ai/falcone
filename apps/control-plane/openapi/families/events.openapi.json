              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Unexpected gateway error."
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Fetch one workspace-scoped event topic contract, transport policy, and replay window under the events family",
        "tags": [
