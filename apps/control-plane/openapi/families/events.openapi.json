{
  "components": {
    "parameters": {
      "IdempotencyKey": {
        "description": "Stable idempotency token for safe retries of POST, PUT, PATCH, and DELETE operations routed through the gateway. Replays are retained for 24h and surfaced through X-Idempotency-Replayed.",
        "in": "header",
        "name": "Idempotency-Key",
        "required": true,
        "schema": {
          "maxLength": 128,
          "minLength": 8,
          "pattern": "^[A-Za-z0-9._:-]{8,128}$",
          "type": "string"
        }
      },
      "ResourceId": {
        "description": "Stable managed resource identifier.",
        "in": "path",
        "name": "resourceId",
        "required": true,
        "schema": {
          "pattern": "^res_[0-9a-z]+$",
          "type": "string"
        }
      },
      "XApiVersion": {
        "description": "Pinned additive contract version for the v1 public API release published with gateway QoS and hardening support.",
        "in": "header",
        "name": "X-API-Version",
        "required": true,
        "schema": {
          "const": "2026-03-24",
          "pattern": "^2026-03-24$",
          "type": "string"
        }
      },
      "XCorrelationId": {
        "description": "Stable request correlation identifier reused by downstream authorization, orchestration, audit flows, and backfilled by the gateway when recovery requires it.",
        "in": "header",
        "name": "X-Correlation-Id",
        "required": true,
        "schema": {
          "maxLength": 128,
          "minLength": 8,
          "pattern": "^[A-Za-z0-9._:-]{8,128}$",
          "type": "string"
        }
      }
    },
    "schemas": {
      "ErrorDetail": {
        "additionalProperties": true,
        "properties": {
          "reason": {
            "type": "string"
          },
          "violations": {
            "items": {
              "type": "string"
            },
            "type": "array"
          }
        },
        "type": "object"
      },
      "ErrorResource": {
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "type": {
            "type": "string"
          }
        },
        "required": [
          "path"
        ],
        "type": "object"
      },
      "ErrorResponse": {
        "additionalProperties": false,
        "properties": {
          "code": {
            "pattern": "^GW_[A-Z0-9_]+$",
            "type": "string"
          },
          "correlationId": {
            "maxLength": 128,
            "minLength": 8,
            "pattern": "^[A-Za-z0-9._:-]{8,128}$",
            "type": "string"
          },
          "detail": {
            "$ref": "#/components/schemas/ErrorDetail"
          },
          "message": {
            "type": "string"
          },
          "requestId": {
            "maxLength": 128,
            "minLength": 8,
            "type": "string"
          },
          "resource": {
            "$ref": "#/components/schemas/ErrorResource"
          },
          "retryable": {
            "type": "boolean"
          },
          "status": {
            "maximum": 599,
            "minimum": 400,
            "type": "integer"
          },
          "timestamp": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "status",
          "code",
          "message",
          "detail",
          "requestId",
          "correlationId",
          "timestamp",
          "resource"
        ],
        "type": "object"
      },
      "EventPublicationAccepted": {
        "additionalProperties": false,
        "properties": {
          "acceptedAt": {
            "format": "date-time",
            "type": "string"
          },
          "auditRecordId": {
            "pattern": "^aud_[0-9a-z]+$",
            "type": "string"
          },
          "channel": {
            "maxLength": 160,
            "minLength": 3,
            "type": "string"
          },
          "correlationId": {
            "maxLength": 128,
            "minLength": 8,
            "type": "string"
          },
          "deliverySemantics": {
            "enum": [
              "at_least_once"
            ],
            "type": "string"
          },
          "partitionKey": {
            "maxLength": 120,
            "minLength": 1,
            "type": "string"
          },
          "publicationId": {
            "pattern": "^pub_[0-9a-z]+$",
            "type": "string"
          },
          "requestId": {
            "maxLength": 128,
            "minLength": 8,
            "type": "string"
          },
          "status": {
            "enum": [
              "accepted",
              "queued"
            ],
            "type": "string"
          },
          "topicName": {
            "maxLength": 120,
            "minLength": 3,
            "type": "string"
          }
        },
        "required": [
          "publicationId",
          "requestId",
          "status",
          "topicName",
          "channel",
          "deliverySemantics",
          "auditRecordId",
          "acceptedAt",
          "correlationId"
        ],
        "type": "object"
      },
      "EventPublicationRequest": {
        "additionalProperties": false,
        "properties": {
          "channel": {
            "maxLength": 160,
            "minLength": 3,
            "type": "string"
          },
          "contentType": {
            "enum": [
              "application/json",
              "application/cloudevents+json"
            ],
            "type": "string"
          },
          "eventType": {
            "maxLength": 120,
            "minLength": 3,
            "type": "string"
          },
          "headers": {
            "additionalProperties": {
              "maxLength": 256,
              "type": "string"
            },
            "type": "object"
          },
          "orderingKey": {
            "maxLength": 120,
            "minLength": 1,
            "type": "string"
          },
          "partitionKey": {
            "maxLength": 120,
            "minLength": 1,
            "type": "string"
          },
          "payload": {
            "additionalProperties": true,
            "type": "object"
          },
          "tenantId": {
            "pattern": "^ten_[0-9a-z]+$",
            "type": "string"
          },
          "workspaceId": {
            "pattern": "^wrk_[0-9a-z]+$",
            "type": "string"
          }
        },
        "required": [
          "tenantId",
          "workspaceId",
          "channel",
          "eventType",
          "contentType",
          "payload"
        ],
        "type": "object"
      },
      "EventTopic": {
        "additionalProperties": false,
        "properties": {
          "allowedTransports": {
            "items": {
              "enum": [
                "http_publish",
                "sse",
                "websocket"
              ],
              "type": "string"
            },
            "minItems": 1,
            "type": "array"
          },
          "auditMode": {
            "enum": [
              "metadata_only",
              "headers_and_denials"
            ],
            "type": "string"
          },
          "channelPrefix": {
            "maxLength": 120,
            "minLength": 3,
            "type": "string"
          },
          "deliverySemantics": {
            "enum": [
              "at_least_once",
              "exactly_once_candidate"
            ],
            "type": "string"
          },
          "maxConcurrentSubscriptions": {
            "maximum": 10000,
            "minimum": 1,
            "type": "integer"
          },
          "maxPublishesPerSecond": {
            "maximum": 5000,
            "minimum": 1,
            "type": "integer"
          },
          "partitionStrategy": {
            "enum": [
              "tenant_workspace_key",
              "channel_key",
              "producer_key"
            ],
            "type": "string"
          },
          "replayWindowHours": {
            "maximum": 720,
            "minimum": 1,
            "type": "integer"
          },
          "resourceId": {
            "pattern": "^res_[0-9a-z]+$",
            "type": "string"
          },
          "retentionHours": {
            "maximum": 8760,
            "minimum": 1,
            "type": "integer"
          },
          "status": {
            "enum": [
              "provisioning",
              "active",
              "suspended"
            ],
            "type": "string"
          },
          "tenantId": {
            "pattern": "^ten_[0-9a-z]+$",
            "type": "string"
          },
          "timestamps": {
            "$ref": "#/components/schemas/LifecycleTimestamps"
          },
          "topicName": {
            "maxLength": 120,
            "minLength": 3,
            "type": "string"
          },
          "workspaceId": {
            "pattern": "^wrk_[0-9a-z]+$",
            "type": "string"
          }
        },
        "required": [
          "resourceId",
          "tenantId",
          "workspaceId",
          "topicName",
          "channelPrefix",
          "deliverySemantics",
          "partitionStrategy",
          "retentionHours",
          "replayWindowHours",
          "allowedTransports",
          "maxPublishesPerSecond",
          "maxConcurrentSubscriptions",
          "status",
          "timestamps"
        ],
        "type": "object"
      },
      "EventTopicWriteRequest": {
        "additionalProperties": false,
        "properties": {
          "allowedTransports": {
            "items": {
              "enum": [
                "http_publish",
                "sse",
                "websocket"
              ],
              "type": "string"
            },
            "minItems": 1,
            "type": "array"
          },
          "channelPrefix": {
            "maxLength": 120,
            "minLength": 3,
            "type": "string"
          },
          "deliverySemantics": {
            "enum": [
              "at_least_once",
              "exactly_once_candidate"
            ],
            "type": "string"
          },
          "maxConcurrentSubscriptions": {
            "maximum": 10000,
            "minimum": 1,
            "type": "integer"
          },
          "maxPublishesPerSecond": {
            "maximum": 5000,
            "minimum": 1,
            "type": "integer"
          },
          "partitionStrategy": {
            "enum": [
              "tenant_workspace_key",
              "channel_key",
              "producer_key"
            ],
            "type": "string"
          },
          "replayWindowHours": {
            "maximum": 720,
            "minimum": 1,
            "type": "integer"
          },
          "retentionHours": {
            "maximum": 8760,
            "minimum": 1,
            "type": "integer"
          },
          "tenantId": {
            "pattern": "^ten_[0-9a-z]+$",
            "type": "string"
          },
          "topicName": {
            "maxLength": 120,
            "minLength": 3,
            "type": "string"
          },
          "workspaceId": {
            "pattern": "^wrk_[0-9a-z]+$",
            "type": "string"
          }
        },
        "required": [
          "tenantId",
          "workspaceId",
          "topicName",
          "channelPrefix",
          "deliverySemantics",
          "partitionStrategy",
          "retentionHours",
          "replayWindowHours",
          "allowedTransports",
          "maxPublishesPerSecond",
          "maxConcurrentSubscriptions"
        ],
        "type": "object"
      },
      "GatewayMutationAccepted": {
        "additionalProperties": false,
        "properties": {
          "acceptedAt": {
            "format": "date-time",
            "type": "string"
          },
          "correlationId": {
            "maxLength": 128,
            "minLength": 8,
            "type": "string"
          },
          "family": {
            "type": "string"
          },
          "requestId": {
            "maxLength": 128,
            "minLength": 8,
            "type": "string"
          },
          "resourceId": {
            "type": "string"
          },
          "resourceType": {
            "type": "string"
          },
          "status": {
            "enum": [
              "accepted",
              "queued"
            ],
            "type": "string"
          }
        },
        "required": [
          "requestId",
          "status",
          "family",
          "resourceType",
          "resourceId",
          "correlationId",
          "acceptedAt"
        ],
        "type": "object"
      },
      "LifecycleTimestamps": {
        "additionalProperties": false,
        "properties": {
          "activatedAt": {
            "format": "date-time",
            "type": "string"
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          },
          "deletedAt": {
            "format": "date-time",
            "type": "string"
          },
          "suspendedAt": {
            "format": "date-time",
            "type": "string"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "createdAt",
          "updatedAt"
        ],
        "type": "object"
      }
    }
  },
  "info": {
    "description": "Workspace-scoped event topics with controlled HTTP publish, SSE delivery, replay windows, and audit-friendly gateway semantics. Generated from the unified public API contract for v1.",
    "summary": "Workspace-scoped event topics with controlled HTTP publish, SSE delivery, replay windows, and audit-friendly gateway semantics.",
    "title": "In Atelier Events API",
    "version": "1.7.0"
  },
  "jsonSchemaDialect": "https://json-schema.org/draft/2020-12/schema",
  "openapi": "3.1.0",
  "paths": {
    "/v1/events/topics": {
      "post": {
        "operationId": "createEvents",
        "parameters": [
          {
            "$ref": "#/components/parameters/XApiVersion"
          },
          {
            "$ref": "#/components/parameters/XCorrelationId"
          },
          {
            "$ref": "#/components/parameters/IdempotencyKey"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EventTopicWriteRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "202": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GatewayMutationAccepted"
                }
              }
            },
            "description": "Event topic provisioning request accepted."
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "The request is malformed or contextually inconsistent."
          },
          "403": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "The caller is authenticated but not authorized for this scope."
          },
          "413": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Gateway rejected the request because the body exceeded the configured size budget for this route family."
          },
          "429": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Gateway QoS policy rejected the request rate for this route family."
          },
          "431": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Gateway rejected one or more invalid or oversized request headers."
          },
          "504": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Gateway timed out while waiting for the downstream control-plane or adapter response."
          },
          "default": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Unexpected gateway error."
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Submit a workspace-scoped event topic and gateway policy provisioning request through the unified events family",
        "tags": [
          "Events"
        ],
        "x-audiences": [
          "developer_external",
          "workspace_owner",
          "workspace_admin",
          "workspace_operator",
          "platform_team"
        ],
        "x-downstream-adapters": [
          "kafka"
        ],
        "x-family": "events",
        "x-owning-service": "event_gateway",
        "x-rate-limit-class": "data-control",
        "x-resource-type": "topic",
        "x-scope": "workspace",
        "x-visibility": "public"
      }
    },
