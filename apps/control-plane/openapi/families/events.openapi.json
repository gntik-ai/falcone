    "/v1/events/topics/{resourceId}/stream": {
      "get": {
        "operationId": "streamTopicEvents",
        "parameters": [
          {
            "$ref": "#/components/parameters/XApiVersion"
          },
          {
            "$ref": "#/components/parameters/XCorrelationId"
          },
          {
            "$ref": "#/components/parameters/ResourceId"
          },
          {
            "description": "Opaque replay cursor or Last-Event-ID checkpoint.",
            "in": "query",
            "name": "cursor",
            "required": false,
            "schema": {
              "maxLength": 160,
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "maxEvents",
            "required": false,
            "schema": {
              "default": 100,
              "maximum": 500,
              "minimum": 1,
              "type": "integer"
            }
          },
          {
            "in": "query",
            "name": "heartbeatSeconds",
            "required": false,
            "schema": {
              "default": 15,
              "maximum": 60,
              "minimum": 5,
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
