{
  "components": {
    "parameters": {
      "IdempotencyKey": {
        "description": "Stable idempotency token for safe retries of POST, PUT, PATCH, and DELETE operations routed through the gateway. Replays are retained for 24h and surfaced through X-Idempotency-Replayed.",
        "in": "header",
        "name": "Idempotency-Key",
        "required": true,
        "schema": {
          "maxLength": 128,
          "minLength": 8,
          "pattern": "^[A-Za-z0-9._:-]{8,128}$",
          "type": "string"
        }
      },
      "XApiVersion": {
        "description": "Pinned additive contract version for the v1 public API release published with gateway QoS and hardening support.",
        "in": "header",
        "name": "X-API-Version",
        "required": true,
        "schema": {
          "const": "2026-03-24",
          "pattern": "^2026-03-24$",
          "type": "string"
        }
      },
      "XCorrelationId": {
        "description": "Stable request correlation identifier reused by downstream authorization, orchestration, audit flows, and backfilled by the gateway when recovery requires it.",
        "in": "header",
        "name": "X-Correlation-Id",
        "required": true,
        "schema": {
          "maxLength": 128,
          "minLength": 8,
          "pattern": "^[A-Za-z0-9._:-]{8,128}$",
          "type": "string"
        }
      }
    },
    "schemas": {
      "ErrorDetail": {
        "additionalProperties": true,
        "properties": {
          "reason": {
            "type": "string"
          },
          "violations": {
            "items": {
              "type": "string"
            },
            "type": "array"
          }
        },
        "type": "object"
      },
      "ErrorResource": {
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "type": {
            "type": "string"
          }
        },
        "required": [
          "path"
        ],
        "type": "object"
      },
      "ErrorResponse": {
        "additionalProperties": false,
        "properties": {
          "code": {
            "pattern": "^GW_[A-Z0-9_]+$",
            "type": "string"
          },
          "correlationId": {
            "maxLength": 128,
            "minLength": 8,
            "pattern": "^[A-Za-z0-9._:-]{8,128}$",
            "type": "string"
          },
          "detail": {
            "$ref": "#/components/schemas/ErrorDetail"
          },
          "message": {
            "type": "string"
          },
          "requestId": {
            "maxLength": 128,
            "minLength": 8,
            "type": "string"
          },
          "resource": {
            "$ref": "#/components/schemas/ErrorResource"
          },
          "retryable": {
            "type": "boolean"
          },
          "status": {
            "maximum": 599,
            "minimum": 400,
            "type": "integer"
          },
          "timestamp": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "status",
          "code",
          "message",
          "detail",
          "requestId",
          "correlationId",
          "timestamp",
          "resource"
        ],
        "type": "object"
      },
      "EventBackpressurePolicy": {
        "additionalProperties": false,
        "properties": {
          "maxDeliveriesPerSecond": {
            "maximum": 5000,
            "minimum": 1,
            "type": "integer"
          },
          "maxInFlight": {
            "maximum": 5000,
            "minimum": 1,
            "type": "integer"
          },
          "maxPublishesPerSecond": {
            "maximum": 5000,
            "minimum": 1,
            "type": "integer"
          },
          "overflowAction": {
            "enum": [
              "429_reject",
              "session_throttle",
              "disconnect"
            ],
            "type": "string"
          },
          "strategy": {
            "enum": [
              "bounded_queue",
              "reject_new",
              "disconnect_slowest_consumer"
            ],
            "type": "string"
          }
        },
        "required": [
          "strategy",
          "maxInFlight",
          "maxPublishesPerSecond",
          "maxDeliveriesPerSecond",
          "overflowAction"
        ],
        "type": "object"
      },
      "EventSubscriptionRequest": {
        "additionalProperties": false,
        "properties": {
          "batchSize": {
            "maximum": 500,
            "minimum": 1,
            "type": "integer"
          },
          "channel": {
            "maxLength": 160,
            "minLength": 3,
            "type": "string"
          },
          "cursorStart": {
            "enum": [
              "latest",
              "earliest",
              "last_event_id"
            ],
            "type": "string"
          },
          "filters": {
            "additionalProperties": {
              "maxLength": 120,
              "type": "string"
            },
            "type": "object"
          },
          "replayWindowHours": {
            "maximum": 720,
            "minimum": 1,
            "type": "integer"
          },
          "topicName": {
            "maxLength": 120,
            "minLength": 3,
            "type": "string"
          }
        },
        "required": [
          "topicName",
          "channel",
          "cursorStart",
          "batchSize"
        ],
        "type": "object"
      },
      "GatewayMutationAccepted": {
        "additionalProperties": false,
        "properties": {
          "acceptedAt": {
            "format": "date-time",
            "type": "string"
          },
          "correlationId": {
            "maxLength": 128,
            "minLength": 8,
            "type": "string"
          },
          "family": {
            "type": "string"
          },
          "requestId": {
            "maxLength": 128,
            "minLength": 8,
            "type": "string"
          },
          "resourceId": {
            "type": "string"
          },
          "resourceType": {
            "type": "string"
          },
          "status": {
            "enum": [
              "accepted",
              "queued"
            ],
            "type": "string"
          }
        },
        "required": [
          "requestId",
          "status",
          "family",
          "resourceType",
          "resourceId",
          "correlationId",
          "acceptedAt"
        ],
        "type": "object"
      },
      "WebSocketSession": {
        "additionalProperties": false,
        "properties": {
          "auditRecordId": {
            "pattern": "^aud_[0-9a-z]+$",
            "type": "string"
          },
          "backpressure": {
            "$ref": "#/components/schemas/EventBackpressurePolicy"
          },
          "channel": {
            "maxLength": 160,
            "minLength": 3,
            "type": "string"
          },
          "expiresAt": {
            "format": "date-time",
            "type": "string"
          },
          "handshakeUrl": {
            "format": "uri",
            "type": "string"
          },
          "heartbeatSeconds": {
            "maximum": 60,
            "minimum": 5,
            "type": "integer"
          },
          "sessionId": {
            "pattern": "^wss_[0-9a-z]+$",
            "type": "string"
          },
          "status": {
            "enum": [
              "pending",
              "active",
              "closed"
            ],
            "type": "string"
          },
          "subprotocol": {
            "enum": [
              "in_atelier.event.v1"
            ],
            "type": "string"
          },
          "subscriptions": {
            "items": {
              "$ref": "#/components/schemas/EventSubscriptionRequest"
            },
            "minItems": 1,
            "type": "array"
          },
          "tenantId": {
            "pattern": "^ten_[0-9a-z]+$",
            "type": "string"
          },
          "workspaceId": {
            "pattern": "^wrk_[0-9a-z]+$",
            "type": "string"
          }
        },
        "required": [
          "sessionId",
          "tenantId",
          "workspaceId",
          "channel",
          "handshakeUrl",
          "expiresAt",
          "status",
          "subscriptions",
          "heartbeatSeconds",
          "backpressure"
        ],
        "type": "object"
      },
      "WebSocketSessionWriteRequest": {
        "additionalProperties": false,
        "properties": {
          "channel": {
            "maxLength": 160,
            "minLength": 3,
            "type": "string"
          },
          "heartbeatSeconds": {
            "maximum": 60,
            "minimum": 5,
            "type": "integer"
          },
          "mode": {
            "enum": [
              "subscribe",
              "publish_subscribe"
            ],
            "type": "string"
          },
          "protocol": {
            "enum": [
              "ws",
              "wss"
            ],
            "type": "string"
          },
          "subscriptions": {
            "items": {
              "$ref": "#/components/schemas/EventSubscriptionRequest"
            },
            "maxItems": 10,
            "minItems": 1,
            "type": "array"
          },
          "tenantId": {
            "pattern": "^ten_[0-9a-z]+$",
            "type": "string"
          },
          "workspaceId": {
            "pattern": "^wrk_[0-9a-z]+$",
            "type": "string"
          }
        },
        "required": [
          "tenantId",
          "workspaceId",
          "channel",
          "subscriptions"
        ],
        "type": "object"
      }
    }
  },
  "info": {
    "description": "Realtime websocket session negotiation and channel subscriptions for workspace-scoped event delivery through the gateway. Generated from the unified public API contract for v1.",
    "summary": "Realtime websocket session negotiation and channel subscriptions for workspace-scoped event delivery through the gateway.",
    "title": "In Atelier WebSockets API",
    "version": "1.12.0"
  },
  "jsonSchemaDialect": "https://json-schema.org/draft/2020-12/schema",
  "openapi": "3.1.0",
  "paths": {
    "/v1/websockets/sessions": {
      "post": {
        "operationId": "createWebSocketSession",
        "parameters": [
          {
            "$ref": "#/components/parameters/XApiVersion"
          },
          {
            "$ref": "#/components/parameters/XCorrelationId"
          },
          {
            "$ref": "#/components/parameters/IdempotencyKey"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WebSocketSessionWriteRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "202": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GatewayMutationAccepted"
                }
              }
            },
            "description": "Websocket session accepted."
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "The request is malformed or contextually inconsistent."
          },
          "403": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "The caller is authenticated but not authorized for this scope."
          },
          "413": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Gateway rejected the request because the body exceeded the configured size budget for this route family."
          },
          "429": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Gateway QoS policy rejected the request rate for this route family."
          },
          "431": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Gateway rejected one or more invalid or oversized request headers."
          },
          "504": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Gateway timed out while waiting for the downstream control-plane or adapter response."
          },
          "default": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Unexpected realtime negotiation error."
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Negotiate one websocket session for gateway-managed topic subscriptions",
        "tags": [
          "WebSockets"
        ],
        "x-audiences": [
          "developer_external",
          "workspace_owner",
          "workspace_admin",
          "workspace_developer",
          "workspace_service_account",
          "platform_team"
        ],
        "x-downstream-adapters": [
          "kafka"
        ],
        "x-family": "websockets",
        "x-owning-service": "event_gateway",
        "x-rate-limit-class": "realtime",
        "x-resource-type": "websocket_session",
        "x-scope": "workspace",
        "x-visibility": "public"
      }
    },
    "/v1/websockets/sessions/{sessionId}": {
      "get": {
        "operationId": "getWebSocketSession",
        "parameters": [
          {
            "$ref": "#/components/parameters/XApiVersion"
          },
          {
            "$ref": "#/components/parameters/XCorrelationId"
          },
          {
            "in": "path",
            "name": "sessionId",
            "required": true,
            "schema": {
              "pattern": "^wss_[0-9a-z]+$",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WebSocketSession"
                }
              }
            },
            "description": "Websocket session returned."
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "The request is malformed or contextually inconsistent."
          },
          "403": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "The caller is authenticated but not authorized for this scope."
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "The requested session was not found."
          },
          "429": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Gateway QoS policy rejected the request rate for this route family."
          },
          "431": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Gateway rejected one or more invalid or oversized request headers."
          },
          "504": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Gateway timed out while waiting for the downstream control-plane or adapter response."
          },
          "default": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Unexpected realtime lookup error."
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Fetch one negotiated websocket session descriptor, subscriptions, and backpressure policy",
        "tags": [
          "WebSockets"
        ],
        "x-audiences": [
          "developer_external",
          "workspace_owner",
          "workspace_admin",
          "workspace_developer",
          "workspace_viewer",
          "workspace_service_account",
          "platform_team"
        ],
        "x-downstream-adapters": [
          "kafka"
        ],
        "x-family": "websockets",
        "x-owning-service": "event_gateway",
        "x-rate-limit-class": "realtime",
        "x-resource-type": "websocket_session",
        "x-scope": "workspace",
        "x-visibility": "public"
      }
    }
  },
  "servers": [
    {
      "url": "https://{publicHost}",
      "variables": {
        "publicHost": {
          "default": "api.dev.in-atelier.example.com",
          "enum": [
            "api.dev.in-atelier.example.com",
            "api.sandbox.in-atelier.example.com",
            "api.staging.in-atelier.example.com",
            "api.in-atelier.example.com"
          ]
        }
      }
    }
  ],
  "tags": [
    {
      "name": "WebSockets"
    }
  ]
}
