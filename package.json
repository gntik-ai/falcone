    "validate:observability-hard-limit-enforcement": "node ./scripts/validate-observability-hard-limit-enforcement.mjs",
    "validate:observability-audit-pipeline": "node ./scripts/validate-observability-audit-pipeline.mjs",
    "validate:observability-audit-event-schema": "node ./scripts/validate-observability-audit-event-schema.mjs",
    "validate:repo": "npm run validate:structure && npm run validate:adr:postgres && npm run validate:image-policy && npm run validate:testing-strategy && npm run validate:service-map && npm run validate:public-api && npm run validate:gateway-policy && npm run validate:deployment-topology && npm run validate:deployment-chart && npm run validate:authorization-model && npm run validate:observability-metrics-stack && npm run validate:observability-dashboards && npm run validate:observability-health-checks && npm run validate:observability-business-metrics && npm run validate:observability-usage-consumption && npm run validate:observability-quota-policies && npm run validate:observability-threshold-alerts && npm run validate:observability-hard-limit-enforcement && npm run validate:observability-quota-usage-view && npm run validate:observability-console-alerts && npm run validate:observability-audit-pipeline && npm run validate:observability-audit-event-schema && npm run validate:observability-audit-query-surface && npm run validate:observability-audit-export-surface && npm run validate:observability-audit-correlation-surface && npm run validate:domain-model",
    "lint:md": "markdownlint-cli2",
    "lint": "npm run validate:repo && npm run lint:md && npm run validate:openapi",
    "lint:snippets": "node scripts/lint-snippet-templates.mjs",
    "test:unit": "node --test tests/unit/*.test.mjs",
    "test:adapters": "node --test tests/adapters/*.test.mjs",
    "test:contracts": "node --test tests/contracts/*.test.mjs",
    "test:e2e:console": "node --test tests/e2e/console/*.test.mjs",
    "test:e2e:deployment": "node --test tests/e2e/deployment/*.test.mjs",
    "test:e2e:observability": "node --test tests/e2e/observability/*.test.mjs",
    "test:e2e:workflows": "node --test tests/e2e/workflows/*.test.mjs",
    "test:e2e:restore": "node --test tests/e2e/workflows/restore/*.test.mjs",
    "test:e2e:realtime": "node --test --test-reporter=tap tests/e2e/realtime/**/*.test.mjs",
    "test:unit:realtime": "node --test tests/unit/realtime/**/*.test.mjs",
    "test:resilience": "node --test tests/resilience/*.test.mjs",
    "test:hardening": "node tests/hardening/run.mjs",
    "test": "npm run test:unit && npm run test:adapters && npm run test:contracts && npm run test:e2e:console && npm run test:e2e:deployment && npm run test:e2e:observability && npm run test:resilience && npm run test:e2e:workflows",
    "test:snippets": "node --test scripts/lint-snippet-templates.test.mjs",
    "test:workspace-docs-service": "node --test services/workspace-docs-service/tests/*.test.mjs",
    "typecheck": "node -e \"console.log('typecheck placeholder: no typed packages yet')\"",
    "security:deps": "corepack pnpm audit --audit-level=high",
    "security:images": "npm run validate:image-policy",
    "sbom:licenses": "pnpm licenses list",
    "sbom:licenses:json": "pnpm licenses list --json",
    "validate:domain-model": "node ./scripts/validate-domain-model.mjs",
    "validate:gateway-policy": "node scripts/validate-gateway-policy.mjs",
    "validate:observability-health-checks": "node ./scripts/validate-observability-health-checks.mjs",
    "validate:observability-audit-query-surface": "node ./scripts/validate-observability-audit-query-surface.mjs",
    "validate:observability-audit-export-surface": "node ./scripts/validate-observability-audit-export-surface.mjs",
    "validate:observability-audit-correlation-surface": "node ./scripts/validate-observability-audit-correlation-surface.mjs",
    "validate:observability-usage-consumption": "node ./scripts/validate-observability-usage-consumption.mjs",
    "validate:observability-quota-usage-view": "node ./scripts/validate-observability-quota-usage-view.mjs"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "12.1.0",
    "ajv": "8.17.1",
    "kafkajs": "2.2.4",
    "markdownlint-cli2": "0.22.0",
    "mongodb": "6.15.0",
    "pg": "8.14.1",
    "ws": "8.18.1",
    "yaml": "2.8.3"
  },
  "pnpm": {
    "overrides": {
      "axios": ">=1.16.0",
      "esbuild": ">=0.25.0",
      "picomatch": ">=2.3.2",
      "fast-uri": "^3.1.2",
      "fast-xml-parser": "^5.7.0",
      "fast-xml-builder": "^1.1.7",
      "react-router": "^6.30.4",
      "brace-expansion@5": ">=5.0.6",
      "follow-redirects": "^1.16.0",
      "postcss": "^8.5.10",
      "vite": "^6.4.3",
      "ws": "^8.21.0",
      "protobufjs": "^7.6.1",
      "form-data": "^4.0.6",
      "ajv": "^8.18.0",
      "dompurify": "^3.4.11",
      "lodash-es": "^4.18.0",
      "markdown-it": "^14.2.0",
      "@babel/core": "^7.29.6",
      "js-yaml@4": "^4.2.0"
    },
    "auditConfig": {
      "ignoreGhsas": [
        "GHSA-r5fr-rjxr-66jc",
        "GHSA-gv7w-rqvm-qjhr"
      ]
    }
  }
}
