{
  "name": "in-atelier",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "validate:structure": "node ./scripts/validate-structure.mjs",
    "validate:adr:postgres": "node ./scripts/validate-postgresql-tenant-isolation.mjs",
    "validate:openapi": "node ./scripts/validate-openapi.mjs",
    "validate:image-policy": "node ./scripts/validate-image-policy.mjs",
    "validate:testing-strategy": "node ./scripts/validate-testing-strategy.mjs",
    "validate:service-map": "node ./scripts/validate-service-map.mjs",
    "generate:public-api": "node ./scripts/generate-public-api-artifacts.mjs",
    "validate:public-api": "node ./scripts/validate-public-api.mjs",
    "validate:deployment-topology": "node ./scripts/validate-deployment-topology.mjs",
    "validate:deployment-chart": "node ./scripts/validate-deployment-chart.mjs",
    "validate:authorization-model": "node ./scripts/validate-authorization-model.mjs",
    "validate:repo": "npm run validate:structure && npm run validate:adr:postgres && npm run validate:image-policy && npm run validate:testing-strategy && npm run validate:service-map && npm run validate:public-api && npm run validate:gateway-policy && npm run validate:deployment-topology && npm run validate:deployment-chart && npm run validate:authorization-model && npm run validate:domain-model",
    "lint:md": "markdownlint-cli2",
    "lint": "npm run validate:repo && npm run lint:md && npm run validate:openapi",
    "test:unit": "node --test tests/unit/*.test.mjs",
    "test:adapters": "node --test tests/adapters/*.test.mjs",
    "test:contracts": "node --test tests/contracts/*.test.mjs",
    "test:e2e:console": "node --test tests/e2e/console/*.test.mjs",
    "test:e2e:deployment": "node --test tests/e2e/deployment/*.test.mjs",
    "test:resilience": "node --test tests/resilience/*.test.mjs",
    "test": "npm run test:unit && npm run test:adapters && npm run test:contracts && npm run test:e2e:console && npm run test:e2e:deployment && npm run test:resilience",
    "typecheck": "node -e \"console.log('typecheck placeholder: no typed packages yet')\"",
    "security:deps": "corepack pnpm audit --audit-level=high",
    "security:images": "npm run validate:image-policy",
    "validate:domain-model": "node ./scripts/validate-domain-model.mjs",
    "validate:gateway-policy": "node scripts/validate-gateway-policy.mjs"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "12.1.0",
    "markdownlint-cli2": "0.22.0",
    "yaml": "2.8.3"
  },
  "pnpm": {
    "overrides": {
      "picomatch": ">=2.3.2"
    }
  }
}
